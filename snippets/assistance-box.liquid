<div class="assistance-box border rounded p-4 bg-light shadow-sm mt-4">
  <h5 class="fw-bold mb-3"><i class="fa-solid fa-headset me-2 text-primary"></i>{{ 'products.general.need_help' | t }}</h5>
  <div class="d-flex flex-column gap-3">
    {% if section.settings.help_phone != blank %}
      <div class="d-flex align-items-center gap-3">
        <div class="assistance-icon rounded-circle d-flex align-items-center justify-content-center bg-primary text-white" style="width: 40px; height: 40px; min-width: 40px;">
          <i class="fa-solid fa-phone"></i>
        </div>
        <div>
          <span class="d-block text-muted small fw-medium">{{ 'products.general.call_us' | t }}</span>
          <a href="tel:{{ section.settings.help_phone }}" class="fw-bold text-dark text-decoration-none">{{ section.settings.help_phone }}</a>
        </div>
      </div>
    {% endif %}

    {% if section.settings.help_email != blank %}
      <div class="d-flex align-items-center gap-3">
        <div class="assistance-icon rounded-circle d-flex align-items-center justify-content-center bg-primary text-white" style="width: 40px; height: 40px; min-width: 40px;">
          <i class="fa-solid fa-envelope"></i>
        </div>
        <div>
          <span class="d-block text-muted small fw-medium">{{ 'products.general.email_us' | t }}</span>
          <a href="mailto:{{ section.settings.help_email }}" class="fw-bold text-dark text-decoration-none">{{ section.settings.help_email }}</a>
        </div>
      </div>
    {% endif %}
  </div>
  
  {% if section.settings.help_hours != blank %}
    <div class="mt-3 pt-3 border-top text-muted small d-flex align-items-center gap-2">
      <i class="fa-regular fa-clock text-primary"></i>
      <span>{{ 'products.general.mon_fri' | t }}: {{ section.settings.help_hours }}</span>
    </div>
  {% endif %}
</div>
