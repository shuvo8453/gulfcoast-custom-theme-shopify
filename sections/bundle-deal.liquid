{% if product.metafields.custom.bundle_products.value != blank %}
  <div class="gcf-bundle-section container my-5 p-4 border rounded shadow-sm" 
       data-discount-value="{{ section.settings.discount_value }}"
       data-discount-type="{{ section.settings.discount_type }}">
    <h4 class="gcf-bundle-title fw-bold text-dark mb-4 border-bottom pb-2">
      <i class="fa-solid fa-layer-group me-2 text-primary"></i>{{ section.settings.title | escape }}
    </h4>
    
    <div class="bundle-products-grid d-flex flex-column gap-3">
      <!-- Main Product -->
      <div class="bundle-product-card d-flex align-items-center justify-content-between gap-3 is-main" 
           data-variant-id="{{ product.selected_or_first_available_variant.id }}" 
           data-price="{{ product.selected_or_first_available_variant.price }}">
        <div class="d-flex align-items-center gap-3">
          <div class="form-check">
            <input type="checkbox" checked disabled class="form-check-input bundle-checkbox" id="main-product-check">
          </div>
          {% if product.featured_image != blank %}
            <img src="{{ product.featured_image | image_url: width: 120 }}" class="rounded border" style="width: 60px; height: 60px; object-fit: cover;" alt="{{ product.title | escape }}" loading="lazy">
          {% endif %}
          <div>
            <h6 class="mb-0 text-dark fw-bold">{{ product.title }}</h6>
            <span class="text-muted small">This Item</span>
          </div>
        </div>
        <div>
          <span class="fw-bold text-primary">{{ product.price | money }}</span>
        </div>
      </div>

      <!-- Secondary Products linked via Metafields -->
      {% for bundle_p in product.metafields.custom.bundle_products.value %}
        {% if bundle_p.available %}
          <div class="bundle-product-card d-flex align-items-center justify-content-between gap-3" 
               data-variant-id="{{ bundle_p.selected_or_first_available_variant.id }}" 
               data-price="{{ bundle_p.selected_or_first_available_variant.price }}">
            <div class="d-flex align-items-center gap-3">
              <div class="form-check">
                <input type="checkbox" checked class="form-check-input bundle-checkbox" id="bundle-product-{{ forloop.index }}">
              </div>
              {% if bundle_p.featured_image != blank %}
                <img src="{{ bundle_p.featured_image | image_url: width: 120 }}" class="rounded border" style="width: 60px; height: 60px; object-fit: cover;" alt="{{ bundle_p.title | escape }}" loading="lazy">
              {% endif %}
              <div>
                <h6 class="mb-0 text-dark fw-bold"><a href="{{ bundle_p.url }}" class="text-dark">{{ bundle_p.title }}</a></h6>
                <span class="text-muted small">Bundle Addon</span>
              </div>
            </div>
            <div>
              <span class="fw-bold text-primary">{{ bundle_p.price | money }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Calculations Footer -->
    <div class="bundle-footer mt-4 pt-3 border-top d-flex justify-content-between align-items-center flex-wrap gap-3">
      <div>
        <span class="d-block text-muted small fw-medium">{{ 'products.product.bundle_total' | t }}</span>
        <span class="fs-4 fw-bold text-primary bundle-total-price"></span>
      </div>
      <button type="button" class="btn btn-primary add-bundle-to-cart px-4 py-2 text-uppercase fs-6">
        <i class="fa-solid fa-cart-plus me-2"></i>{{ 'products.product.add_bundle' | t }}
      </button>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Product Bundle Builder",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Bought Together"
    },
    {
      "type": "number",
      "id": "discount_value",
      "label": "Discount Amount (Numeric)",
      "default": 10
    },
    {
      "type": "select",
      "id": "discount_type",
      "label": "Discount Type",
      "options": [
        {
          "value": "percentage",
          "label": "Percentage (%)"
        },
        {
          "value": "fixed",
          "label": "Fixed Discount ($)"
        }
      ],
      "default": "percentage"
    }
  ],
  "presets": [
    {
      "name": "Product Bundle Builder"
    }
  ]
}
{% endschema %}
