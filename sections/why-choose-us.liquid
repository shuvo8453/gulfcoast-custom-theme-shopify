<section class="why-choose-us-section gcf-section-padding bg-white">
  <div class="container">
    <div class="row align-items-center g-5">
      <!-- Left Column: Heading and Description -->
      <div class="col-12 col-lg-5">
        {% if section.settings.subtitle != blank %}
          <span class="d-block gcf-section-subtitle">{{ section.settings.subtitle | escape }}</span>
        {% endif %}
        {% if section.settings.title != blank %}
          <h2 class="gcf-section-title fw-bold text-dark mb-4">{{ section.settings.title | escape }}</h2>
        {% endif %}
        {% if section.settings.content != blank %}
          <p class="gcf-section-content leading-relaxed text-muted">{{ section.settings.content | escape }}</p>
        {% endif %}
        {% if section.settings.btn_label != blank %}
          <a href="{{ section.settings.btn_link }}" class="btn btn-primary btn-lg rounded-pill px-4 text-uppercase">
            {{ section.settings.btn_label }}
          </a>
        {% endif %}
      </div>

      <!-- Right Column: Features Grid List -->
      <div class="col-12 col-lg-7">
        <div class="row row-cols-1 row-cols-sm-2 g-4">
          {% for block in section.blocks %}
            <div class="col" {{ block.shopify_attributes }}>
              <div class="feature-item p-4 border rounded shadow-sm bg-light h-100 transition hover:-translate-y-1">
                <div class="feature-icon rounded-circle d-flex align-items-center justify-content-center bg-primary text-white mb-3" style="width: 50px; height: 50px; font-size: 20px;">
                  <i class="fa-solid {{ block.settings.icon_class | default: 'fa-check' }}"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">{{ block.settings.title }}</h5>
                <p class="text-muted small leading-relaxed mb-0">{{ block.settings.text }}</p>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Why Choose Us",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub-title",
      "default": "Our Commitment"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Choose Gulf Coast Outfitters"
    },
    {
      "type": "textarea",
      "id": "content",
      "label": "Description Text",
      "default": "We offer premium quality gear designed specifically for Destin and Gulf Coast conditions, with expert customer advice and hassle-free support."
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "About Our Team"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Card",
      "settings": [
        {
          "type": "text",
          "id": "icon_class",
          "label": "FontAwesome Icon Class Name",
          "default": "fa-certificate"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Feature Title",
          "default": "Premium Quality"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Feature Description Text",
          "default": "Every item is rigorously tested to ensure performance in local marine environments."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "feature", "settings": { "icon_class": "fa-medal", "title": "Tested Locally", "text": "Designed and vetted specifically for the waters of the Florida Gulf Coast." } },
        { "type": "feature", "settings": { "icon_class": "fa-life-ring", "title": "Lifetime Support", "text": "Unmatched post-purchase support and answers for any technical issues." } }
      ]
    }
  ]
}
{% endschema %}
