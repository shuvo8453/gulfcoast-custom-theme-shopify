{%- style -%}
  #MarinersTrust-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #MarinersTrust-{{ section.id }} .mt-section-title {
    color: {{ section.settings.title_color }};
    font-family: 'Outfit', sans-serif;
    font-size: 36px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 auto 50px;
    max-width: 600px;
    text-align: center;
  }
  #MarinersTrust-{{ section.id }} .trust-item {
    text-align: center;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  #MarinersTrust-{{ section.id }} .trust-badge-outer {
    position: relative;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background-color: {{ section.settings.circle_ring_color | default: '#ffffff' | color_modify: 'alpha', 0.12 }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #MarinersTrust-{{ section.id }} .trust-item:hover .trust-badge-outer {
    transform: scale(1.05);
  }
  #MarinersTrust-{{ section.id }} .trust-badge-inner {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background-color: {{ section.settings.circle_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.circle_text_color }};
  }
  #MarinersTrust-{{ section.id }} .trust-title {
    color: {{ section.settings.card_title_color }};
    font-family: 'Outfit', sans-serif;
    font-size: 20px;
    font-weight: 700;
    margin: 0 0 12px;
    line-height: 1.4;
  }
  #MarinersTrust-{{ section.id }} .trust-text {
    color: {{ section.settings.card_text_color }};
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    max-width: 260px;
  }
  @media (max-width: 767px) {
    #MarinersTrust-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    #MarinersTrust-{{ section.id }} .mt-section-title {
      font-size: 28px;
      margin-bottom: 40px;
    }
    #MarinersTrust-{{ section.id }} .trust-badge-outer {
      margin-bottom: 16px;
    }
    #MarinersTrust-{{ section.id }} .trust-title {
      font-size: 18px;
      margin-bottom: 8px;
    }
  }
{%- endstyle -%}

<section id="MarinersTrust-{{ section.id }}" class="mariners-trust-section">
  <div class="container">
    {%- if section.settings.title != blank -%}
      <h2 class="mt-section-title">{{ section.settings.title | escape }}</h2>
    {%- endif -%}

    <div class="row row-cols-{{ section.settings.columns_mobile | default: 1 }} row-cols-md-{{ section.settings.columns_tablet | default: 2 }} row-cols-lg-{{ section.settings.columns_desktop | default: 4 }} g-5 justify-content-center">
      {%- for block in section.blocks -%}
        <div class="col" {{ block.shopify_attributes }}>
          <div class="trust-item">
            <!-- Double Ring Circle Number Badge -->
            <div class="trust-badge-outer">
              <div class="trust-badge-inner">
                {{ forloop.index }}
              </div>
            </div>

            <!-- Content -->
            {%- if block.settings.title != blank -%}
              <h3 class="trust-title">{{ block.settings.title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="trust-text">{{ block.settings.text | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Mariners Trust",
  "max_blocks": 8,
  "settings": [
    {
      "type": "header",
      "content": "Section Header"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Why Mariners Trust Gulf Coast Outfitters?"
    },
    {
      "type": "header",
      "content": "Grid Settings"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Web columns (Desktop)",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Tablet columns",
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobile columns",
      "default": 1
    },
    {
      "type": "header",
      "content": "Styling & Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#061325"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card Title Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_text_color",
      "label": "Card Text Color",
      "default": "#e2e8f0"
    },
    {
      "type": "color",
      "id": "circle_bg_color",
      "label": "Circle Background Color",
      "default": "#4b5e78"
    },
    {
      "type": "color",
      "id": "circle_ring_color",
      "label": "Outer Ring Glow Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "circle_text_color",
      "label": "Circle Number Color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Desktop)",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Top (Mobile)",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom (Mobile)",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust Block",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Expertise"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Get advice from real-world boating professionals."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mariners Trust",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Expertise",
            "text": "Get advice from real-world boating professionals."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Value",
            "text": "We offer competitive, industry-leading prices without compromising quality."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Reach",
            "text": "Fast and reliable nationwide shipping ensures your gear arrives in time."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Support",
            "text": "We offer expert assistance to get your equipment up and running."
          }
        }
      ]
    }
  ]
}
{% endschema %}
