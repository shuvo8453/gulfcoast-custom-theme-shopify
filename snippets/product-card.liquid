<div class="product-card h-100 d-flex flex-column" data-product-id="{{ product.id }}">
  <!-- Product Image Area -->
  <div class="product-card-image position-relative">
    <a href="{{ product.url | within: collection }}" class="d-block w-100 h-100">
      {% if product.featured_image != blank %}
        <img
          src="{{ product.featured_image | image_url: width: 500, height: 500, crop: 'center' }}"
          alt="{{ product.title | escape }}"
          class="img-fluid"
          loading="lazy"
          width="500"
          height="500"
        >
      {% else %}
        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg border rounded' }}
      {% endif %}
    </a>

    <!-- Badges (In Stock / Out of Stock) -->
    {% if product.available %}
      <span
        class="badge bg-success position-absolute top-0 start-0 m-3 rounded-pill px-3 py-2 text-uppercase fw-bold"
        style="z-index: 2; background-color: #009f3d !important;"
      >
        In Stock
      </span>
    {% else %}
      <span
        class="badge bg-danger position-absolute top-0 start-0 m-3 rounded-pill px-3 py-2 text-uppercase fw-bold"
        style="z-index: 2; background-color: #dc3545 !important;"
      >
        Out of Stock
      </span>
    {% endif %}

    <!-- Quick View Trigger Button -->
    <button
      type="button"
      class="quick-view-btn btn position-absolute start-50 rounded-pill border-0 px-3 py-2 text-nowrap"
      style="background-color: #eff6ff; color: #1e3a8a; font-weight: 500; font-size: 13px; z-index: 3; bottom: 12px;"
      data-handle="{{ product.handle }}"
      data-title="{{ product.title | escape }}"
      data-price="{{ product.price | money }}"
      data-compare-price="{% if product.compare_at_price > product.price %}{{ product.compare_at_price | money }}{% endif %}"
      data-image="{{ product.featured_image | image_url: width: 600 }}"
      data-available="{{ product.available }}"
      data-sku="{{ product.variants.first.sku | default: '-' }}"
      data-vendor="{{ product.vendor | escape | default: '-' }}"
      data-url="{{ product.url }}"
      data-weight="{% if product.variants.first.weight > 0 %}{{ product.variants.first.weight | weight_with_unit }}{% else %}-{% endif %}"
      data-dimensions="{% if product.metafields.custom.box_length != blank %}{{ product.metafields.custom.box_length }}{% if product.metafields.custom.box_width != blank %} &times; {{ product.metafields.custom.box_width }}{% endif %}{% if product.metafields.custom.box_height != blank %} &times; {{ product.metafields.custom.box_height }}{% endif %} in{% else %}-{% endif %}"
      data-mpn="{{ product.metafields.custom.manufacturer_part_number | default: '-' }}"
      data-drop-ships="{% if product.metafields.custom.drop_ships_direct.value == true or product.metafields.custom.drop_ships_direct == 'true' or product.metafields.custom.drop_ships_direct == true %}yes{% else %}no{% endif %}"
      data-hazardous="{% if product.metafields.custom.hazardous_materials.value == true or product.metafields.custom.hazardous_materials == 'true' or product.metafields.custom.hazardous_materials == true %}yes{% else %}no{% endif %}"
      data-truck-freight="{% if product.metafields.custom.truck_freight.value == true or product.metafields.custom.truck_freight == 'true' or product.metafields.custom.truck_freight == true %}yes{% else %}no{% endif %}"
      data-exportable="{% if product.metafields.custom.exportable.value == true or product.metafields.custom.exportable == 'true' or product.metafields.custom.exportable == true %}yes{% else %}no{% endif %}"
      data-first-class="{% if product.metafields.custom.first_class_mail.value == true or product.metafields.custom.first_class_mail == 'true' or product.metafields.custom.first_class_mail == true %}yes{% else %}no{% endif %}"
      data-oversized="{% if product.metafields.custom.oversized.value == true or product.metafields.custom.oversized == 'true' or product.metafields.custom.oversized == true %}yes{% else %}no{% endif %}"
      data-remanufactured="{% if product.metafields.custom.remanufactured.value == true or product.metafields.custom.remanufactured == 'true' or product.metafields.custom.remanufactured == true %}yes{% else %}no{% endif %}"
      data-closeout="{% if product.metafields.custom.closeout.value == true or product.metafields.custom.closeout == 'true' or product.metafields.custom.closeout == true %}yes{% else %}no{% endif %}"
      data-country-origin="{{ product.metafields.custom.country_of_origin | default: '-' }}"
      data-prop-65="{% if product.metafields.custom.prop_65.value == true or product.metafields.custom.prop_65 == 'true' or product.metafields.custom.prop_65 == true %}yes{% else %}no{% endif %}"
      data-returnable="{% if product.metafields.custom.returnable.value == true or product.metafields.custom.returnable == 'true' or product.metafields.custom.returnable == true %}yes{% else %}no{% endif %}"
      data-google-category="{{ product.metafields.custom.google_merchant_category | default: '-' }}"
      data-categories="{% for col in product.collections %}{{ col.title }}{% unless forloop.last %}, {% endunless %}{% endfor %}"
      data-variant-id="{{ product.selected_or_first_available_variant.id }}"
      data-inventory-quantity="{{ product.selected_or_first_available_variant.inventory_quantity }}"
      data-inventory-management="{{ product.selected_or_first_available_variant.inventory_management }}"
    >
      <i class="fa-regular fa-eye me-1"></i> Quick View
    </button>
  </div>

  <!-- Product Details Info -->
  <div class="product-card-info p-3 d-flex flex-column flex-grow-1">
    <!-- Vendor -->
    <span class="text-uppercase text-muted small fw-bold tracking-wider mb-1" style="font-size: 11px;">
      {{- product.vendor -}}
    </span>

    <!-- Title -->
    <h6 class="product-card-title fw-bold mb-2">
      <a href="{{ product.url | within: collection }}" class="text-dark hover:text-primary text-decoration-none">
        {{ product.title }}
      </a>
    </h6>

    <!-- Stock Status Pill (Green for In Stock, Red for Out of Stock) -->
    <div class="product-card-stock mb-2">
      {% if product.available %}
        {% assign card_variant = product.selected_or_first_available_variant %}
        {% if card_variant.inventory_management != blank
          and card_variant.inventory_quantity > 0
          and card_variant.inventory_quantity <= 10
        %}
          {% if card_variant.inventory_quantity <= 5 %}
            <span
              class="stock-status-pill"
              style="background-color: #ffeff1 !important; color: #b31b1b !important; border: 1px solid #ffcfd6 !important; border-radius: 60px; padding: 4px 12px; font-size: 14px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;"
            >
              <i class="fa-solid fa-triangle-exclamation"></i> Only {{ card_variant.inventory_quantity }} left – order
              soon!
            </span>
          {% else %}
            <span
              class="stock-status-pill"
              style="background-color: #ffedd5 !important; color: #ea580c !important; border: 1px solid #ffedd5 !important; border-radius: 60px; padding: 4px 12px; font-size: 14px; font-weight: 600; display: inline-flex; align-items: center; gap: 6px;"
            >
              <i class="fa-solid fa-bolt-lightning"></i> Low stock – selling fast
            </span>
          {% endif %}
        {% else %}
          <span class="stock-status-pill stock-in"> <i class="fa-solid fa-circle-check"></i> In stock </span>
        {% endif %}
      {% else %}
        <span class="stock-status-pill stock-out"> <i class="fa-solid fa-circle-xmark"></i> Out of stock </span>
      {% endif %}
    </div>

    <!-- Pricing -->
    <div class="product-card-price mt-auto pt-2 border-top border-light-subtle d-flex flex-column gap-1 mb-3">
      <div class="d-flex align-items-center gap-2">
        <span class="fw-bold text-primary">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="text-muted text-decoration-line-through small">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>

      {% assign admin_email = settings.admin_email | default: 'tfl8453@gmail.com' %}
      {% if customer and customer.email == admin_email %}
        {% if product.metafields.custom.purchase_price.value != blank
          or product.metafields.custom.purchase_price != blank
        %}
          <div
            class="purchase-price-admin-card text-warning-emphasis d-flex align-items-center gap-1"
            style="font-size: 11px; font-weight: 600; border: 1px dashed #ffc107; padding: 2px 6px; border-radius: 4px; background-color: #fffdf5; width: fit-content;"
          >
            <i class="fa-solid fa-user-shield" style="font-size: 10px;"></i>
            <span
              >P. Price:
              {% if product.metafields.custom.purchase_price.value != blank %}
                {{ product.metafields.custom.purchase_price.value | times: 100 | money }}
              {% else %}
                {{ product.metafields.custom.purchase_price | times: 100 | money }}
              {% endif %}
            </span>
          </div>
        {% endif %}
      {% endif %}
    </div>

    <!-- Actions Footer (Wishlist, Compare, Add to Cart or Notify) -->
    <div class="product-card-buttons d-flex align-items-center gap-2 mt-auto w-100">
      <button
        class="card-action-btn wishlist-btn-toggle"
        data-handle="{{ product.handle }}"
        aria-label="Add to Wishlist"
        title="Add to Wishlist"
      >
        <i class="fa-regular fa-heart"></i>
      </button>
      <button
        class="card-action-btn compare-btn-toggle"
        data-handle="{{ product.handle }}"
        aria-label="Compare Product"
        title="Compare Product"
      >
        <i class="fa-solid fas fa-exchange-alt"></i>
      </button>

      {% if product.available %}
        <form method="post" action="/cart/add" class="d-inline-block flex-grow-1 mb-0">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            class="btn btn-primary product-card-btn-add w-100 py-2 d-flex align-items-center justify-content-center gap-2 text-white border-0"
            style="background-color: var(--color-primary); border-radius: 60px;"
          >
            <i class="fa-solid fa-cart-shopping"></i> <span class="d-none d-sm-inline">Add To Cart</span>
          </button>
        </form>
      {% else %}
        <button
          type="button"
          class="btn btn-danger product-card-btn-notify flex-grow-1 py-2 d-flex align-items-center justify-content-center gap-2 text-white border-0"
          style="background-color: #ff0000; border-radius: 60px;"
          data-bs-toggle="modal"
          data-bs-target="#notifyModal"
          data-product-sku="{{ product.selected_or_first_available_variant.sku | default: '' }}"
          data-product-title="{{ product.title | escape }}"
          data-product-url="{{ shop.url }}{{ product.url }}"
        >
          <i class="fa-regular fa-bell"></i> <span class="d-none d-sm-inline">Notify</span>
        </button>
      {% endif %}
    </div>
  </div>
</div>
