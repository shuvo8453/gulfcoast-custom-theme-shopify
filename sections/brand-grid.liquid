{% comment %}
  Brand Grid Section - Loops dynamically through shop.vendors and matches them with merchant-uploaded logos in blocks.
{% endcomment %}

<div class="brand-grid-section brand-grid-section-{{ section.id }}">
  <div class="brand-grid-container">
    {%- if section.settings.subtitle != blank -%}
      <p class="brand-grid-subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}
    
    {%- if section.settings.heading != blank -%}
      <h2 class="brand-grid-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="brand-grid-layout">
      {%- for vendor in shop.vendors -%}
        {%- assign matched_logo = blank -%}
        
        {%- comment -%}
          Search through blocks to find a matching vendor name
        {%- endcomment -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'brand_logo' -%}
            {%- assign block_vendor_normalized = block.settings.vendor_name | strip | downcase -%}
            {%- assign current_vendor_normalized = vendor | strip | downcase -%}
            {%- if block_vendor_normalized == current_vendor_normalized -%}
              {%- assign matched_logo = block.settings.brand_logo -%}
              {%- break -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        <a href="{{ vendor | url_for_vendor }}" class="brand-grid-card" title="{{ vendor | escape }}">
          <div class="brand-grid-card-logo-wrapper">
            {%- if matched_logo != blank -%}
              <img
                class="brand-grid-card-logo"
                src="{{ matched_logo | image_url: width: 300 }}"
                alt="{{ vendor | escape }} Logo"
                loading="lazy"
                width="auto"
                height="auto"
              >
            {%- else -%}
              {%- comment -%}Fallback to stylized letter circle placeholder{%- endcomment -%}
              <div class="brand-grid-card-placeholder">
                <span class="brand-grid-card-placeholder-letter">
                  {{ vendor | slice: 0 | upcase }}
                </span>
              </div>
            {%- endif -%}
          </div>
          <span class="brand-grid-card-name">{{ vendor }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

<style>
  .brand-grid-section-{{ section.id }} {
    padding: 60px 20px;
    background-color: transparent;
    font-family: {{ section.settings.font_family }};
  }
  .brand-grid-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    margin-top: 0;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin-top: 0;
    margin-bottom: 40px;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-layout {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 24px;
  }
  .brand-grid-card {
    background-color: #ffffff;
    border: 1px solid #4a77ce;
    border-radius: 16px;
    padding: 30px 20px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 180px;
    box-sizing: border-box;
  }
  .brand-grid-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(74, 119, 206, 0.15);
  }
  .brand-grid-card-logo-wrapper {
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    width: 100%;
  }
  .brand-grid-card-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .brand-grid-card-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #f0f4fc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a77ce;
    border: 1px solid #e2e8f0;
  }
  .brand-grid-card-placeholder-letter {
    font-size: 24px;
    font-weight: 700;
  }
  .brand-grid-card-name {
    font-size: 14px;
    font-weight: 600;
    color: #333333;
    transition: color 0.2s ease;
  }
  .brand-grid-card:hover .brand-grid-card-name {
    color: #4a77ce;
  }

  /* Responsive breakpoints */
  @media screen and (min-width: 768px) {
    .brand-grid-section-{{ section.id }} .brand-grid-layout {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }
  @media screen and (min-width: 992px) {
    .brand-grid-section-{{ section.id }} .brand-grid-layout {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Brand Grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "POPULAR BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Are You Shopping For?"
    },
    {
      "type": "header",
      "content": "Design & Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family Stack",
      "options": [
        {
          "value": "system-ui, -apple-system, sans-serif",
          "label": "System Sans-Serif"
        },
        {
          "value": "'Helvetica Neue', Helvetica, Arial, sans-serif",
          "label": "Helvetica/Arial"
        },
        {
          "value": "Georgia, serif",
          "label": "Georgia Serif"
        }
      ],
      "default": "system-ui, -apple-system, sans-serif"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#4a77ce"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle Font Size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitle Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0b1a4a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 18,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Responsive Grid Columns"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on Tablet",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "brand_logo",
      "name": "Brand Logo Mapping",
      "settings": [
        {
          "type": "text",
          "id": "vendor_name",
          "label": "Vendor Name",
          "info": "Must match the product vendor name exactly (case insensitive)."
        },
        {
          "type": "image_picker",
          "id": "brand_logo",
          "label": "Brand Logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Brand Grid",
      "blocks": []
    }
  ]
}
{% endschema %}

