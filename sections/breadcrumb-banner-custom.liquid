{%- style -%}
  /* Base Container Styling */
  #breadcrumb-section-{{ section.id }} {
    position: relative;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    {%- if section.settings.bg_image != blank -%}
      background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
      background-size: {{ section.settings.bg_image_size }};
      background-position: {{ section.settings.bg_image_position }};
      background-repeat: no-repeat;
    {%- else -%}
      background: {{ section.settings.bg_color }};
      {%- if section.settings.bg_gradient != blank -%}
        background: {{ section.settings.bg_gradient }};
      {%- endif -%}
    {%- endif -%}
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* Background Overlay */
  {%- if section.settings.bg_image != blank and section.settings.show_overlay -%}
    #breadcrumb-section-{{ section.id }}::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: {{ section.settings.overlay_color }};
      opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      z-index: 1;
    }
  {%- endif -%}

  /* Inner Container */
  .breadcrumb-container-{{ section.id }} {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ section.settings.max_width }}px;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
    margin-left: auto;
    margin-right: auto;
    box-sizing: border-box;
  }

  /* Flex Alignment for Mobile */
  .breadcrumb-wrapper-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: {{ section.settings.alignment_mobile }};
    text-align: {{ section.settings.alignment_mobile }};
  }

  /* Breadcrumb Navigation Styling */
  .breadcrumb-nav-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: {% if section.settings.alignment_mobile == 'center' %}center{% elsif section.settings.alignment_mobile == 'right' %}flex-end{% else %}flex-start{% endif %};
    gap: 6px;
    margin-bottom: {{ section.settings.breadcrumb_margin_bottom_mobile }}px;
    list-style: none;
    padding: 0;
  }

  .breadcrumb-item-{{ section.id }} {
    font-family: {{ section.settings.breadcrumb_font_family }};
    font-size: {{ section.settings.breadcrumb_size_mobile }}px;
    font-weight: {{ section.settings.breadcrumb_font_weight }};
    line-height: 1.4;
  }

  .breadcrumb-item-{{ section.id }} a {
    color: {{ section.settings.breadcrumb_link_color }};
    text-decoration: none;
    transition: color 0.2s ease-in-out;
  }

  .breadcrumb-item-{{ section.id }} a:hover {
    color: {{ section.settings.breadcrumb_link_hover_color }};
  }

  .breadcrumb-item-{{ section.id }}.active-page {
    color: {{ section.settings.breadcrumb_active_color }};
  }

  .breadcrumb-separator-{{ section.id }} {
    color: {{ section.settings.separator_color }};
    margin: 0;
    display: inline-flex;
    align-items: center;
    font-size: {{ section.settings.breadcrumb_size_mobile }}px;
  }

  /* Page Title Styling */
  .breadcrumb-title-{{ section.id }} {
    font-family: {{ section.settings.title_font_family }};
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    margin: 0;
    line-height: 1.2;
    letter-spacing: {{ section.settings.title_letter_spacing_mobile }}px;
  }

  /* Tablet Devices (576px to 767px) */
  @media screen and (min-width: 576px) {
    #breadcrumb-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
    }

    .breadcrumb-container-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal_tablet }}px;
      padding-right: {{ section.settings.padding_horizontal_tablet }}px;
    }

    .breadcrumb-wrapper-{{ section.id }} {
      align-items: {{ section.settings.alignment_tablet }};
      text-align: {{ section.settings.alignment_tablet }};
    }

    .breadcrumb-nav-{{ section.id }} {
      justify-content: {% if section.settings.alignment_tablet == 'center' %}center{% elsif section.settings.alignment_tablet == 'right' %}flex-end{% else %}flex-start{% endif %};
      margin-bottom: {{ section.settings.breadcrumb_margin_bottom_tablet }}px;
    }

    .breadcrumb-item-{{ section.id }} {
      font-size: {{ section.settings.breadcrumb_size_tablet }}px;
    }

    .breadcrumb-separator-{{ section.id }} {
      font-size: {{ section.settings.breadcrumb_size_tablet }}px;
    }

    .breadcrumb-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_tablet }}px;
      letter-spacing: {{ section.settings.title_letter_spacing_tablet }}px;
    }
  }

  /* Desktop Devices (768px and up) */
  @media screen and (min-width: 768px) {
    #breadcrumb-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }

    .breadcrumb-container-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal_desktop }}px;
      padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    }

    .breadcrumb-wrapper-{{ section.id }} {
      align-items: {{ section.settings.alignment_desktop }};
      text-align: {{ section.settings.alignment_desktop }};
    }

    .breadcrumb-nav-{{ section.id }} {
      justify-content: {% if section.settings.alignment_desktop == 'center' %}center{% elsif section.settings.alignment_desktop == 'right' %}flex-end{% else %}flex-start{% endif %};
      margin-bottom: {{ section.settings.breadcrumb_margin_bottom_desktop }}px;
    }

    .breadcrumb-item-{{ section.id }} {
      font-size: {{ section.settings.breadcrumb_size_desktop }}px;
    }

    .breadcrumb-separator-{{ section.id }} {
      font-size: {{ section.settings.breadcrumb_size_desktop }}px;
    }

    .breadcrumb-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_desktop }}px;
      letter-spacing: {{ section.settings.title_letter_spacing_desktop }}px;
    }
  }
{%- endstyle -%}

<section id="breadcrumb-section-{{ section.id }}" class="breadcrumb-banner-custom">
  <div class="breadcrumb-container-{{ section.id }}">
    <div class="breadcrumb-wrapper-{{ section.id }}">
      {%- comment -%} Breadcrumbs Navigation {%- endcomment -%}
      {%- unless template == 'index' -%}
        <ol class="breadcrumb-nav-{{ section.id }}" role="navigation" aria-label="breadcrumbs">
          <li class="breadcrumb-item-{{ section.id }}">
            <a href="{{ routes.root_url }}">{{ 'general.breadcrumbs.home' | t | default: 'Home' }}</a>
          </li>

          {%- if template contains 'product' -%}
            {%- if collection -%}
              <li class="breadcrumb-separator-{{ section.id }}">
                {{ section.settings.separator }}
              </li>
              <li class="breadcrumb-item-{{ section.id }}">
                <a href="{{ collection.url }}">{{ collection.title }}</a>
              </li>
            {%- endif -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">{{ product.title }}</li>

          {%- elsif template contains 'collection' and collection.handle -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            {%- if current_tags -%}
              <li class="breadcrumb-item-{{ section.id }}">
                <a href="{{ collection.url }}">{{ collection.title }}</a>
              </li>
              <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
              <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">
                {{ current_tags | join: ' + ' }}
              </li>
            {%- else -%}
              <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">{{ collection.title }}</li>
            {%- endif -%}

          {%- elsif template == 'blog' -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            {%- if current_tags -%}
              <li class="breadcrumb-item-{{ section.id }}">
                <a href="{{ blog.url }}">{{ blog.title }}</a>
              </li>
              <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
              <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">
                {{ current_tags | join: ' + ' }}
              </li>
            {%- else -%}
              <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">{{ blog.title }}</li>
            {%- endif -%}

          {%- elsif template == 'article' -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }}">
              <a href="{{ blog.url }}">{{ blog.title }}</a>
            </li>
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">{{ article.title }}</li>

          {%- elsif template == 'cart' -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">
              {{ 'cart.general.title' | t | default: 'Your Cart' }}
            </li>

          {%- elsif template == 'search' -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">
              {{ 'general.search.search' | t | default: 'Search' }}
            </li>

          {%- else -%}
            <li class="breadcrumb-separator-{{ section.id }}">{{ section.settings.separator }}</li>
            <li class="breadcrumb-item-{{ section.id }} active-page" aria-current="page">{{ page_title }}</li>
          {%- endif -%}
        </ol>
      {%- endunless -%}

      {%- comment -%} Page Title {%- endcomment -%}
      {%- if section.settings.show_title -%}
        <h1 class="breadcrumb-title-{{ section.id }}">
          {%- if template contains 'product' -%}
            {{ product.title }}
          {%- elsif template contains 'collection' -%}
            {{ collection.title }}
          {%- elsif template == 'blog' -%}
            {{ blog.title }}
          {%- elsif template == 'article' -%}
            {{ article.title }}
          {%- elsif template == 'cart' -%}
            {{ 'cart.general.title' | t | default: 'Your Cart' }}
          {%- elsif template == 'search' -%}
            {{ 'general.search.heading' | t | default: 'Search Results' }}
          {%- else -%}
            {{ page_title }}
          {%- endif -%}
        </h1>
      {%- endif -%}
    </div>
  </div>
</section>

