<section class="blog-archive-section py-5">
  <div class="container">
    {% render 'breadcrumb' %}

    <div class="row g-5 mt-2">
      <!-- Main Content (Articles Grid) -->
      <div class="col-12 col-lg-9">
        <h1 class="blog-title fw-bold text-dark mb-4">{{ blog.title }}</h1>

        {% paginate blog.articles by section.settings.posts_per_page %}
          {% if blog.articles.size > 0 %}
            <div class="row row-cols-1 row-cols-md-2 g-4">
              {% for article in blog.articles %}
                <div class="col">
                  <article class="card h-100 shadow-sm border border-light-subtle rounded overflow-hidden">
                    {% if article.image %}
                      <a href="{{ article.url }}">
                        <img src="{{ article.image | image_url: width: 600 }}" class="card-img-top" style="height: 220px; object-fit: cover;" alt="{{ article.title | escape }}" loading="lazy">
                      </a>
                    {% endif %}
                    
                    <div class="card-body p-4">
                      <!-- Date / Author -->
                      <div class="article-meta text-muted small mb-2 d-flex align-items-center gap-2">
                        <span>{{ article.published_at | time_tag: format: 'date' }}</span>
                        <span>&bull;</span>
                        <span>{{ 'blogs.article.by_author' | t: author: article.author }}</span>
                      </div>

                      <h5 class="card-title fw-bold"><a href="{{ article.url }}" class="text-dark hover:text-primary">{{ article.title }}</a></h5>
                      <p class="card-text text-muted small mt-2">
                        {% if article.excerpt.size > 0 %}
                          {{ article.excerpt | strip_html | truncatewords: 30 }}
                        {% else %}
                          {{ article.content | strip_html | truncatewords: 30 }}
                        {% endif %}
                      </p>
                    </div>
                    
                    <div class="card-footer bg-transparent border-0 px-4 pb-4 pt-0">
                      <a href="{{ article.url }}" class="btn btn-outline-primary btn-sm rounded-pill px-3">{{ 'blogs.article.read_more' | t }}</a>
                    </div>
                  </article>
                </div>
              {% endfor %}
            </div>

            <!-- Pagination -->
            {% if paginate.pages > 1 %}
              <nav class="d-flex justify-content-center mt-5" aria-label="Page navigation">
                <ul class="pagination pagination-sm">
                  {% if paginate.previous %}
                    <li class="page-item"><a class="page-link rounded-circle px-3 py-2 me-2" href="{{ paginate.previous.url }}"><i class="fa-solid fa-chevron-left"></i></a></li>
                  {% endif %}
                  
                  {% for part in paginate.parts %}
                    {% if part.is_link %}
                      <li class="page-item"><a class="page-link rounded-circle px-3 py-2 me-2" href="{{ part.url }}">{{ part.title }}</a></li>
                    25:                 {% else %}
                      <li class="page-item active"><span class="page-link rounded-circle px-3 py-2 me-2">{{ part.title }}</span></li>
                    {% endif %}
                  {% endfor %}

                  {% if paginate.next %}
                    <li class="page-item"><a class="page-link rounded-circle px-3 py-2" href="{{ paginate.next.url }}"><i class="fa-solid fa-chevron-right"></i></a></li>
                  {% endif %}
                </ul>
              </nav>
            {% endif %}
          {% else %}
            <p class="text-muted">No posts available in this blog.</p>
          {% endif %}
        {% endpaginate %}
      </div>

      <!-- Blog Sidebar -->
      <div class="col-12 col-lg-3">
        <aside class="blog-sidebar d-flex flex-column gap-5">
          <!-- Widget: Recent Articles -->
          <div class="sidebar-widget p-4 border rounded bg-light shadow-sm">
            <h5 class="fw-bold mb-3 border-bottom pb-2">Recent Posts</h5>
            <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
              {% for article in blog.articles limit: 5 %}
                <li class="d-flex gap-3 align-items-center">
                  {% if article.image %}
                    <img src="{{ article.image | image_url: width: 100 }}" class="rounded" style="width: 50px; height: 50px; object-fit: cover;" alt="{{ article.title | escape }}">
                  {% endif %}
                  <div class="min-w-0">
                    <h6 class="mb-0 text-dark small fw-bold text-truncate"><a href="{{ article.url }}" class="text-dark">{{ article.title }}</a></h6>
                    <span class="text-muted small text-xs" style="font-size: 11px;">{{ article.published_at | time_tag: format: 'date' }}</span>
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>

          <!-- Widget: Meta tags list -->
          {% if blog.all_tags.size > 0 %}
            <div class="sidebar-widget p-4 border rounded bg-light shadow-sm">
              <h5 class="fw-bold mb-3 border-bottom pb-2">Categories</h5>
              <div class="d-flex flex-wrap gap-2">
                {% for tag in blog.all_tags %}
                  <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="badge bg-secondary-subtle text-secondary border px-3 py-2 text-decoration-none rounded-pill small">{{ tag }}</a>
                {% endfor %}
              </div>
            </div>
          {% endif %}
        </aside>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Blog Grid",
  "settings": [
    {
      "type": "range",
      "id": "posts_per_page",
      "min": 4,
      "max": 20,
      "step": 2,
      "label": "Posts per page",
      "default": 6
    }
  ]
}
{% endschema %}
