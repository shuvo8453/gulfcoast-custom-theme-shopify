{% comment %}
  Brand Grid Section - Loops dynamically through shop.vendors and matches them with merchant-uploaded logos in blocks.
{% endcomment %}

<div class="brand-grid-section brand-grid-section-{{ section.id }}">
  <div class="brand-grid-container">
    {%- if section.settings.subtitle != blank -%}
      <p class="brand-grid-subtitle">{{ section.settings.subtitle | escape }}</p>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h2 class="brand-grid-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <!-- Brand Grid Search Bar -->
    <div class="brand-grid-search-wrapper">
      <i class="fa-solid fa-magnifying-glass brand-grid-search-icon"></i>
      <input 
        type="text" 
        id="BrandSearchInput-{{ section.id }}" 
        class="brand-grid-search-input" 
        placeholder="{{ section.settings.search_placeholder | escape }}" 
        aria-label="Search brands"
      >
      <button 
        type="button" 
        id="BrandSearchClear-{{ section.id }}" 
        class="brand-grid-search-clear" 
        aria-label="Clear search"
      >
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

    <div class="brand-grid-layout">
      {%- for vendor in shop.vendors -%}
        {%- assign matched_logo = blank -%}
        {%- assign vendor_handle = vendor | handleize -%}

        {%- for brand in shop.metaobjects.brand.values -%}
          {%- assign brand_name_normalized = brand.name | strip | downcase -%}
          {%- assign current_vendor_normalized = vendor | strip | downcase -%}
          {%- if brand_name_normalized == current_vendor_normalized -%}
            {%- if brand.logo != blank -%}
              {%- assign matched_logo = brand.logo -%}
            {%- endif -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if matched_logo == blank -%}
          {%- assign svg_name = vendor_handle | append: '.svg' -%}
          {%- assign png_name = vendor_handle | append: '.png' -%}
          {%- assign jpg_name = vendor_handle | append: '.jpg' -%}
          {%- assign jpeg_name = vendor_handle | append: '.jpeg' -%}

          {%- if images[svg_name] != blank -%}
            {%- assign matched_logo = images[svg_name] -%}
          {%- elsif images[png_name] != blank -%}
            {%- assign matched_logo = images[png_name] -%}
          {%- elsif images[jpg_name] != blank -%}
            {%- assign matched_logo = images[jpg_name] -%}
          {%- elsif images[jpeg_name] != blank -%}
            {%- assign matched_logo = images[jpeg_name] -%}
          {%- endif -%}
        {%- endif -%}

        <a href="{{ vendor | url_for_vendor }}" class="brand-grid-card" title="{{ vendor | escape }}" data-brand-name="{{ vendor | escape }}">
          <div class="brand-grid-card-logo-wrapper">
            {%- if matched_logo != blank -%}
              <img
                class="brand-grid-card-logo"
                src="{{ matched_logo | image_url: width: 300 }}"
                alt="{{ vendor | escape }} Logo"
                loading="lazy"
                width="auto"
                height="auto"
              >
            {%- else -%}
              {%- comment -%}Fallback to stylized letter circle placeholder{%- endcomment -%}
              <div class="brand-grid-card-placeholder">
                <span class="brand-grid-card-placeholder-letter">
                  {{ vendor | slice: 0 | upcase }}
                </span>
              </div>
            {%- endif -%}
          </div>
          <span class="brand-grid-card-name">{{ vendor }}</span>
        </a>
      {%- endfor -%}
    </div>

    <!-- No Results Message -->
    <div id="BrandNoResults-{{ section.id }}" class="brand-grid-no-results" style="display: none;">
      No brands found matching your search.
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    var searchInput = document.getElementById('BrandSearchInput-{{ section.id }}');
    var clearBtn = document.getElementById('BrandSearchClear-{{ section.id }}');
    var cards = document.querySelectorAll('.brand-grid-section-{{ section.id }} .brand-grid-card');
    var noResults = document.getElementById('BrandNoResults-{{ section.id }}');
    
    if (searchInput && cards.length > 0) {
      searchInput.addEventListener('input', function() {
        var query = searchInput.value.toLowerCase().trim();
        
        if (query.length > 0) {
          clearBtn.classList.add('is-active');
        } else {
          clearBtn.classList.remove('is-active');
        }
        
        var hasVisible = false;
        cards.forEach(function(card) {
          var brandName = card.getAttribute('data-brand-name').toLowerCase();
          if (brandName.indexOf(query) !== -1) {
            card.style.display = 'flex';
            hasVisible = true;
          } else {
            card.style.display = 'none';
          }
        });
        
        if (noResults) {
          noResults.style.display = hasVisible ? 'none' : 'block';
        }
      });
      
      clearBtn.addEventListener('click', function() {
        searchInput.value = '';
        clearBtn.classList.remove('is-active');
        cards.forEach(function(card) {
          card.style.display = 'flex';
        });
        if (noResults) {
          noResults.style.display = 'none';
        }
        searchInput.focus();
      });
    }
  });
</script>

<style>
  .brand-grid-section-{{ section.id }} {
    padding: 60px 20px;
    background-color: transparent;
    font-family: {{ section.settings.font_family }};
  }
  .brand-grid-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-subtitle {
    font-size: {{ section.settings.subtitle_size }}px;
    font-weight: {{ section.settings.subtitle_weight }};
    color: {{ section.settings.subtitle_color }};
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    margin-top: 0;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-heading {
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    margin-top: 0;
    margin-bottom: 30px;
  }
  /* Search Bar Styles */
  .brand-grid-section-{{ section.id }} .brand-grid-search-wrapper {
    position: relative;
    max-width: {{ section.settings.search_max_width }}px;
    margin: 0 auto 40px;
    display: flex;
    align-items: center;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
    border-radius: {{ section.settings.search_border_radius }}px;
    transition: box-shadow 0.3s ease;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-wrapper:focus-within {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-icon {
    position: absolute;
    left: 20px;
    color: {{ section.settings.search_focus_color }};
    font-size: 18px;
    pointer-events: none;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-input {
    width: 100%;
    padding: 14px 50px;
    border: 1px solid {{ section.settings.search_border_color }};
    border-radius: {{ section.settings.search_border_radius }}px;
    font-size: 16px;
    color: {{ section.settings.search_text_color }};
    background-color: {{ section.settings.search_bg_color }};
    outline: none;
    transition: border-color 0.3s ease;
    box-sizing: border-box;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-input:focus {
    border-color: {{ section.settings.search_focus_color }};
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-clear {
    position: absolute;
    right: 20px;
    background: none;
    border: none;
    color: #94a3b8;
    cursor: pointer;
    font-size: 18px;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.2s, visibility 0.2s, color 0.2s;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-clear.is-active {
    opacity: 1;
    visibility: visible;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-search-clear:hover {
    color: {{ section.settings.search_focus_color }};
  }
  .brand-grid-section-{{ section.id }} .brand-grid-no-results {
    padding: 60px 20px;
    color: #64748b;
    font-size: 18px;
    font-weight: 500;
    text-align: center;
    border: 1px dashed #cbd5e1;
    border-radius: 16px;
    background-color: rgba(248, 250, 252, 0.5);
    margin-top: 20px;
  }
  .brand-grid-section-{{ section.id }} .brand-grid-layout {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 24px;
  }
  .brand-grid-card {
    background-color: #ffffff;
    border: 1px solid #4a77ce;
    border-radius: 16px;
    padding: 30px 20px;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    height: 180px;
    box-sizing: border-box;
  }
  .brand-grid-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(74, 119, 206, 0.15);
  }
  .brand-grid-card-logo-wrapper {
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    width: 100%;
  }
  .brand-grid-card-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .brand-grid-card-placeholder {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background-color: #f0f4fc;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #4a77ce;
    border: 1px solid #e2e8f0;
  }
  .brand-grid-card-placeholder-letter {
    font-size: 24px;
    font-weight: 700;
  }
  .brand-grid-card-name {
    font-size: 14px;
    font-weight: 600;
    color: #333333;
    transition: color 0.2s ease;
  }
  .brand-grid-card:hover .brand-grid-card-name {
    color: #4a77ce;
  }

  /* Responsive breakpoints */
  @media screen and (min-width: 768px) {
    .brand-grid-section-{{ section.id }} .brand-grid-layout {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, 1fr);
    }
  }
  @media screen and (min-width: 992px) {
    .brand-grid-section-{{ section.id }} .brand-grid-layout {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Brand Grid",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "POPULAR BRANDS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Are You Shopping For?"
    },
    {
      "type": "header",
      "content": "Design & Fonts"
    },
    {
      "type": "select",
      "id": "font_family",
      "label": "Font Family Stack",
      "options": [
        {
          "value": "system-ui, -apple-system, sans-serif",
          "label": "System Sans-Serif"
        },
        {
          "value": "'Helvetica Neue', Helvetica, Arial, sans-serif",
          "label": "Helvetica/Arial"
        },
        {
          "value": "Georgia, serif",
          "label": "Georgia Serif"
        }
      ],
      "default": "system-ui, -apple-system, sans-serif"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle Color",
      "default": "#4a77ce"
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Subtitle Font Size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "subtitle_weight",
      "label": "Subtitle Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "700"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#0b1a4a"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading Font Size",
      "min": 18,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading Font Weight",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "600", "label": "Semi-Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "header",
      "content": "Responsive Grid Columns"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on Desktop",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns on Tablet",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_mobile",
      "label": "Columns on Mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "header",
      "content": "Search Bar Styling"
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search Placeholder Text",
      "default": "Search brands..."
    },
    {
      "type": "range",
      "id": "search_max_width",
      "label": "Search Bar Max Width (px)",
      "min": 250,
      "max": 800,
      "step": 10,
      "default": 450
    },
    {
      "type": "color",
      "id": "search_border_color",
      "label": "Search Border Color",
      "default": "#cbd5e1"
    },
    {
      "type": "color",
      "id": "search_focus_color",
      "label": "Search Focus/Icon Color",
      "default": "#4a77ce"
    },
    {
      "type": "color",
      "id": "search_text_color",
      "label": "Search Input Text Color",
      "default": "#1e293b"
    },
    {
      "type": "color",
      "id": "search_bg_color",
      "label": "Search Input Background Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "search_border_radius",
      "label": "Search Border Radius (px)",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 50
    }
  ],
  "presets": [
    {
      "name": "Brand Grid"
    }
  ]
}
{% endschema %}
