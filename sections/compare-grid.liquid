<section class="compare-grid-section py-5">
  <div class="container">
    {% render 'breadcrumb' %}

    <div class="row mt-4">
      <div class="col-12">
        <h1 class="fw-bold text-dark mb-4">
          <i class="fa-solid fas fa-exchange-alt text-primary me-2"></i>{{ page.title }}
        </h1>

        <div id="compare-table-container" class="table-responsive border rounded bg-white shadow-sm mt-2">
          <!-- Loaded dynamically via client-side storage -->
          <div class="text-center py-5" id="compare-preloader">
            <i class="fa-solid fa-spinner fa-spin fa-3x text-primary mb-3"></i>
            <p class="text-muted">Loading product comparisons...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const list = JSON.parse(localStorage.getItem('gcf_compare') || '[]');
    const container = document.getElementById('compare-table-container');
    const preloader = document.getElementById('compare-preloader');

    if (!container) return;

    if (list.length === 0) {
      if (preloader) preloader.remove();
      container.parentNode.innerHTML = `
        <div class="text-center py-5 border rounded bg-light">
          <i class="fa-solid fas fa-exchange-alt fa-3x text-muted mb-3"></i>
          <p class="text-muted mb-3">No products selected for comparison.</p>
          <a href="/collections/all" class="btn btn-primary rounded-pill px-4">Browse Products</a>
        </div>
      `;
      return;
    }

    const promises = list.map(
      (handle) =>
        fetch(`/products/${handle}.js`)
          .then((res) => {
            if (!res.ok) throw new Error();
            return res.json();
          })
          .catch(() => null) // Ignore missing products
    );

    Promise.all(promises)
      .then((products) => {
        if (preloader) preloader.remove();

        const validProducts = products.filter((p) => p !== null);
        if (validProducts.length === 0) {
          container.parentNode.innerHTML = `
            <div class="text-center py-5 border rounded bg-light">
              <i class="fa-solid fas fa-exchange-alt fa-3x text-muted mb-3"></i>
              <p class="text-muted mb-3">No products selected for comparison.</p>
              <a href="/collections/all" class="btn btn-primary rounded-pill px-4">Browse Products</a>
            </div>
          `;
          return;
        }

        let tableHeader = `<th class="bg-light fw-bold text-dark w-25">Product Details</th>`;
        let imageRow = `<td><strong>Image</strong></td>`;
        let priceRow = `<td><strong>Price</strong></td>`;
        let vendorRow = `<td><strong>Brand</strong></td>`;
        let descRow = `<td><strong>Overview</strong></td>`;
        let actionRow = `<td><strong>Actions</strong></td>`;

        validProducts.forEach((product) => {
          const formattedPrice = formatMoney(product.price);

          tableHeader += `
            <th class="text-center position-relative w-25">
              <span class="d-block fw-bold text-dark text-truncate">${product.title}</span>
              <button class="btn btn-sm btn-outline-danger border-0 compare-btn-toggle position-absolute top-0 end-0 m-1" data-handle="${product.handle}" title="Remove">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </th>
          `;

          imageRow += `
            <td class="text-center">
              <a href="${product.url}">
                <img src="${product.featured_image}" class="rounded border" style="width: 100px; height: 100px; object-fit: cover;" alt="${product.title}">
              </a>
            </td>
          `;

          priceRow += `<td class="text-center fw-bold text-primary">${formattedPrice}</td>`;
          vendorRow += `<td class="text-center text-muted">${product.vendor}</td>`;

          const cleanDesc =
            product.description
              .replace(/<\/?[^>]+(>|$)/g, '')
              .split(' ')
              .slice(0, 20)
              .join(' ') + '...';
          descRow += `<td class="small leading-normal text-muted">${cleanDesc}</td>`;

          actionRow += `
            <td class="text-center">
              <a href="${product.url}" class="btn btn-primary btn-sm rounded-pill px-3">View Details</a>
            </td>
          `;
        });

        container.innerHTML = `
          <table class="table table-bordered mb-0 align-middle">
            <thead>
              <tr>${tableHeader}</tr>
            </thead>
            <tbody>
              <tr>${imageRow}</tr>
              <tr>${priceRow}</tr>
              <tr>${vendorRow}</tr>
              <tr>${descRow}</tr>
              <tr>${actionRow}</tr>
            </tbody>
          </table>
        `;

        // Bind delete action triggers
        container.querySelectorAll('.compare-btn-toggle').forEach((btn) => {
          btn.addEventListener('click', () => {
            window.location.reload();
          });
        });
      })
      .catch((err) => {
        console.error('Failed to load comparison products:', err);
        if (preloader) preloader.remove();
        container.innerHTML =
          '<p class="text-danger text-center p-4">An error occurred while loading comparison details.</p>';
      });

    function formatMoney(cents) {
      const formatString = window.theme ? window.theme.moneyFormat : '$ {{amount}}';
      const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;

      if (isNaN(cents) || cents == null) return '$0.00';
      let formatted = (cents / 100.0).toFixed(2);

      return formatString.replace(placeholderRegex, formatted);
    }
  });
</script>
