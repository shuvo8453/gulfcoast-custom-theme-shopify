{% comment %}
  Custom Footer Section
  Developed for Gulf Coast Outfitters
{% endcomment %}

{%- style -%}
  .custom-footer {
    width: 100%;
    margin: 0 auto;
    overflow-x: hidden;
  }
  .custom-footer .container-fluid {
    max-width: 1200px;
    margin: 0 auto;
  }

  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    font-family: 'Inter', sans-serif;
    --font-heading: 'Outfit', sans-serif;
    overflow-x: hidden;
  }

  #shopify-section-{{ section.id }} img {
    max-width: 100%;
  }

  #shopify-section-{{ section.id }} a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} a:hover {
    color: {{ section.settings.link_hover_color }};
  }

  /* SECTION 1: Benefit Bar */
  .footer-benefits-{{ section.id }} {
    border-bottom: 1px solid {{ section.settings.border_color }};
    padding: {{ section.settings.benefit_padding_desktop }}px 0;
  }
  .benefits-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ section.settings.benefit_gap_desktop }}px;
    justify-content: center;
    align-items: center;
  }
  .benefit-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 15px;
    justify-content: center;
  }
  .benefit-img-{{ section.id }} {
    display: block;
    object-fit: contain;
    width: {{ section.settings.benefit_img_width_desktop }}px;
    height: {{ section.settings.benefit_img_height_desktop }}px;
  }
  .benefit-text-{{ section.id }} {
    font-size: 15px;
    font-weight: 600;
    margin: 0;
  }

  /* SECTION 2: Main Footer Content */
  .footer-main-{{ section.id }} {
    padding: {{ section.settings.main_padding_desktop }}px 0;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .footer-main-grid-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: {{ section.settings.main_gap_desktop }}px;
    flex-wrap: wrap;
  }
  .brand-column-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    flex: 1 1 25%;
    max-width: 320px;
  }
  .brand-logo-{{ section.id }} {
    display: block;
    object-fit: contain;
    width: {{ section.settings.logo_width_desktop }}px;
    height: {{ section.settings.logo_height_desktop }}px;
    margin-bottom: 20px;
  }
  .brand-desc-{{ section.id }} {
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
    color: {{ section.settings.text_muted_color }};
  }
  .columns-2x2-grid-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    flex: 1 1 70%;
    gap: {{ section.settings.main_gap_desktop }}px;
    flex-wrap: wrap;
  }
  .menu-column-{{ section.id }} {
    flex: 1 1 15%;
    min-width: 140px;
  }
  .contact-column-{{ section.id }} {
    flex: 1 1 20%;
    min-width: 200px;
  }
  .menu-column-{{ section.id }} h3,
  .contact-column-{{ section.id }} h3 {
    font-family: var(--font-heading);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 25px;
    text-transform: uppercase;
    color: {{ section.settings.heading_color }};
  }
  .footer-menu-{{ section.id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-menu-{{ section.id }} li {
    margin-bottom: 12px;
  }
  .footer-menu-{{ section.id }} a {
    font-size: 14px;
  }
  .contact-list-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .contact-item-{{ section.id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
  }
  .contact-icon-{{ section.id }} {
    display: block;
    object-fit: contain;
    width: {{ section.settings.contact_icon_width_desktop }}px;
    height: {{ section.settings.contact_icon_height_desktop }}px;
  }
  i.contact-icon-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: {{ section.settings.contact_icon_width_desktop }}px;
    line-height: 1;
    color: {{ section.settings.link_color }};
  }
  .contact-text-{{ section.id }} {
    line-height: 1.4;
    word-break: break-all;
    color: #b8c5d6;
  }

  /* SECTION 3: Systems & Socials */
  .footer-systems-{{ section.id }} {
    padding: {{ section.settings.systems_padding_desktop }}px 0;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .footer-systems-desktop-{{ section.id }} {
    display: block;
  }
  .footer-systems-mobile-{{ section.id }} {
    display: none;
  }
  .systems-grid-{{ section.id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: {{ section.settings.systems_gap_desktop }}px;
    flex-wrap: wrap;
  }
  .system-block-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1 1 30%;
  }
  .system-block-{{ section.id }} h4 {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 700;
    margin-top: 0;
    margin-bottom: 15px;
    color: {{ section.settings.heading_color }};
  }
  .system-images-{{ section.id }} {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    justify-content: center;
    align-items: center;
  }
  .system-img-{{ section.id }} {
    display: block;
    object-fit: contain;
  }
  .social-links-{{ section.id }} {
    display: flex;
    gap: 12px;
    justify-content: center;
    align-items: center;
  }
  .social-icon-btn-{{ section.id }} {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: {{ section.settings.social_bg_color }};
    color: {{ section.settings.social_icon_color }} !important;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: background-color 0.3s ease, transform 0.2s ease, opacity 0.3s ease;
  }
  .social-icon-btn-{{ section.id }}.facebook {
    background-color: #3b5998;
  }
  .social-icon-btn-{{ section.id }}.instagram {
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285aeb 90%);
  }
  .social-icon-btn-{{ section.id }}.youtube {
    background-color: #ff0000;
  }
  .social-icon-btn-{{ section.id }}:hover {
    background-color: {{ section.settings.social_hover_bg_color }};
    transform: translateY(-2px);
  }
  .social-icon-btn-{{ section.id }}.facebook:hover {
    background-color: #2d4373;
  }
  .social-icon-btn-{{ section.id }}.instagram:hover {
    opacity: 0.9;
    background: radial-gradient(circle at 30% 107%, #fdf497 0%, #fdf497 5%, #fd5949 45%, #d6249f 60%, #285aeb 90%);
  }
  .social-icon-btn-{{ section.id }}.youtube:hover {
    background-color: #cc0000;
  }

  /* SECTION 4: Copyright Bottom */
  .footer-bottom-{{ section.id }} {
    padding: {{ section.settings.bottom_padding_desktop }}px 0;
    text-align: center;
  }
  .copyright-text-{{ section.id }} {
    font-size: 13px;
    margin: 0;
    color: {{ section.settings.text_muted_color }};
  }

  /* TABLET AND MOBILE RESPONSIVE STYLES */
  @media screen and (max-width: 991px) {
    /* Tablet Styles */
    .benefits-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, auto);
      gap: {{ section.settings.benefit_gap_tablet }}px;
    }
    .benefit-img-{{ section.id }} {
      width: {{ section.settings.benefit_img_width_tablet }}px;
      height: {{ section.settings.benefit_img_height_tablet }}px;
    }

    .footer-main-grid-{{ section.id }} {
      display: flex;
      flex-direction: column;
      gap: {{ section.settings.main_gap_tablet }}px;
      text-align: center;
      align-items: center;
    }
    .brand-column-{{ section.id }} {
      align-items: center;
      text-align: center;
      margin-bottom: 20px;
      flex: 1 1 auto;
      max-width: 100%;
    }
    .brand-logo-{{ section.id }} {
      width: {{ section.settings.logo_width_tablet }}px;
      height: {{ section.settings.logo_height_tablet }}px;
      margin-left: auto;
      margin-right: auto;
    }

    .columns-2x2-grid-{{ section.id }} {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, auto);
      gap: {{ section.settings.main_gap_tablet }}px;
      width: 100%;
      flex: 1 1 auto;
    }
    .menu-column-{{ section.id }} h3,
    .contact-column-{{ section.id }} h3 {
      margin-bottom: 15px;
    }
    .contact-item-{{ section.id }} {
      justify-content: center;
    }
    .contact-icon-{{ section.id }} {
      width: {{ section.settings.contact_icon_width_tablet }}px;
      height: {{ section.settings.contact_icon_height_tablet }}px;
    }
    i.contact-icon-{{ section.id }} {
      font-size: {{ section.settings.contact_icon_width_tablet }}px;
    }

    /* Toggle visibility */
    .footer-systems-desktop-{{ section.id }} {
      display: none !important;
    }
    .footer-systems-mobile-{{ section.id }} {
      display: block !important;
      padding: {{ section.settings.systems_padding_desktop }}px 0;
    }
    .systems-mobile-row1-{{ section.id }} {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: {{ section.settings.systems_gap_tablet }}px;
      margin-bottom: 25px;
    }
    .systems-mobile-row1-{{ section.id }} .system-block-{{ section.id }} {
      flex: 1 1 45%;
    }
    .systems-mobile-row2-{{ section.id }} {
      display: flex;
      justify-content: center;
      align-items: center;
      width: 100%;
    }
    .systems-mobile-row2-{{ section.id }} .system-block-{{ section.id }} {
      flex: 1 1 100%;
    }
  }

  @media screen and (max-width: 575px) {
    /* Mobile Styles */
    .footer-benefits-{{ section.id }} {
      padding: {{ section.settings.benefit_padding_mobile }}px 0;
    }
    .benefits-grid-{{ section.id }} {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(2, auto);
      gap: {{ section.settings.benefit_gap_mobile }}px;
    }
    .benefit-img-{{ section.id }} {
      width: {{ section.settings.benefit_img_width_mobile }}px;
      height: {{ section.settings.benefit_img_height_mobile }}px;
    }

    .footer-main-{{ section.id }} {
      padding: {{ section.settings.main_padding_mobile }}px 0;
    }
    .footer-main-grid-{{ section.id }} {
      gap: {{ section.settings.main_gap_mobile }}px;
    }
    .brand-logo-{{ section.id }} {
      width: {{ section.settings.logo_width_mobile }}px;
      height: {{ section.settings.logo_height_mobile }}px;
    }
    .columns-2x2-grid-{{ section.id }} {
      gap: {{ section.settings.main_gap_mobile }}px;
    }
    .contact-icon-{{ section.id }} {
      width: {{ section.settings.contact_icon_width_mobile }}px;
      height: {{ section.settings.contact_icon_height_mobile }}px;
    }
    i.contact-icon-{{ section.id }} {
      font-size: {{ section.settings.contact_icon_width_mobile }}px;
    }

    .footer-systems-mobile-{{ section.id }} {
      padding: {{ section.settings.systems_padding_mobile }}px 0 !important;
    }
    .systems-mobile-row1-{{ section.id }} {
      gap: {{ section.settings.systems_gap_mobile }}px;
    }
  }
{%- endstyle -%}

<div id="custom-footer-{{ section.id }}" class="custom-footer">
  <!-- SECTION 1: Benefit Bar -->
  <div class="footer-benefits-{{ section.id }}">
    <div class="container-fluid px-4 px-md-5">
      <div class="benefits-grid-{{ section.id }}">
        {%- for i in (1..4) -%}
          {%- liquid
            assign img_key = 'benefit_img_' | append: i
            assign text_key = 'benefit_text_' | append: i
            assign img = section.settings[img_key]
            assign text = section.settings[text_key]
          -%}
          {%- if img != blank or text != blank -%}
            <div class="benefit-item-{{ section.id }}">
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 150 }}"
                  alt="{{ text | escape }}"
                  class="benefit-img-{{ section.id }}"
                  loading="lazy"
                  height="auto"
                  width="auto"
                >
              {%- endif -%}
              {%- if text != blank -%}
                <p class="benefit-text-{{ section.id }}">{{ text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  <!-- SECTION 2: Main Footer Content -->
  <div class="footer-main-{{ section.id }}">
    <div class="container-fluid px-4 px-md-5">
      <div class="footer-main-grid-{{ section.id }}">
        <!-- Logo & Description column -->
        <div class="brand-column-{{ section.id }}">
          {%- if section.settings.logo != blank -%}
            <img
              src="{{ section.settings.logo | image_url: width: 400 }}"
              alt="{{ shop.name | escape }}"
              class="brand-logo-{{ section.id }}"
              loading="lazy"
              height="auto"
              width="auto"
            >
          {%- endif -%}
          {%- if section.settings.description != blank -%}
            <p class="brand-desc-{{ section.id }}">{{ section.settings.description }}</p>
          {%- endif -%}
        </div>

        <!-- Desktop Grid vs Tablet 2x2 Grid wrap -->
        <div class="columns-2x2-grid-{{ section.id }}">
          <!-- Column 1: Our Business -->
          <div class="menu-column-{{ section.id }}">
            <h3>{{ section.settings.menu_title_1 }}</h3>
            {%- if section.settings.menu_1 != blank -%}
              <ul class="footer-menu-{{ section.id }}">
                {%- for link in linklists[section.settings.menu_1].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <!-- Column 2: Important Links -->
          <div class="menu-column-{{ section.id }}">
            <h3>{{ section.settings.menu_title_2 }}</h3>
            {%- if section.settings.menu_2 != blank -%}
              <ul class="footer-menu-{{ section.id }}">
                {%- for link in linklists[section.settings.menu_2].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <!-- Column 3: Useful Links -->
          <div class="menu-column-{{ section.id }}">
            <h3>{{ section.settings.menu_title_3 }}</h3>
            {%- if section.settings.menu_3 != blank -%}
              <ul class="footer-menu-{{ section.id }}">
                {%- for link in linklists[section.settings.menu_3].links -%}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

          <!-- Column 4: Available On (Contact details) -->
          <div class="contact-column-{{ section.id }}">
            <h3>{{ section.settings.contact_title }}</h3>
            <div class="contact-list-{{ section.id }}">
              {%- if section.settings.contact_email != blank -%}
                <div class="contact-item-{{ section.id }}">
                  {%- if section.settings.email_icon != blank -%}
                    <img
                      src="{{ section.settings.email_icon | image_url: width: 60 }}"
                      alt="Email"
                      class="contact-icon-{{ section.id }}"
                      loading="lazy"
                      height="auto"
                      width="auto"
                    >
                  {%- else -%}
                    <i class="far fa-envelope contact-icon-{{ section.id }}"></i>
                  {%- endif -%}
                  <span class="contact-text-{{ section.id }}">
                    <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
                  </span>
                </div>
              {%- endif -%}

              {%- if section.settings.contact_phone != blank -%}
                <div class="contact-item-{{ section.id }}">
                  {%- if section.settings.phone_icon != blank -%}
                    <img
                      src="{{ section.settings.phone_icon | image_url: width: 60 }}"
                      alt="Phone"
                      class="contact-icon-{{ section.id }}"
                      loading="lazy"
                      height="auto"
                      width="auto"
                    >
                  {%- else -%}
                    <i class="fas fa-phone-alt contact-icon-{{ section.id }}"></i>
                  {%- endif -%}
                  <span class="contact-text-{{ section.id }}">
                    <a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a>
                  </span>
                </div>
              {%- endif -%}

              {%- if section.settings.contact_address != blank -%}
                <div class="contact-item-{{ section.id }}">
                  {%- if section.settings.address_icon != blank -%}
                    <img
                      src="{{ section.settings.address_icon | image_url: width: 60 }}"
                      alt="Address"
                      class="contact-icon-{{ section.id }}"
                      loading="lazy"
                      height="auto"
                      width="auto"
                    >
                  {%- else -%}
                    <i class="fas fa-map-marker-alt contact-icon-{{ section.id }}"></i>
                  {%- endif -%}
                  <span class="contact-text-{{ section.id }}">{{ section.settings.contact_address }}</span>
                </div>
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 3: Systems & Socials (DESKTOP VERSION) -->
  <div
    id="footer-systems-desktop-{{ section.id }}"
    class="footer-systems-{{ section.id }} footer-systems-desktop-{{ section.id }}"
  >
    <div class="container-fluid px-4 px-md-5">
      <div class="systems-grid-{{ section.id }}">
        <!-- Payment System -->
        <div class="system-block-{{ section.id }} payment-block-{{ section.id }}">
          <h4>{{ section.settings.payment_title }}</h4>
          <div class="system-images-{{ section.id }}">
            {%- for i in (1..6) -%}
              {%- liquid
                assign img_key = 'payment_img_' | append: i
                assign img = section.settings[img_key]
                assign width_key = 'payment_width_' | append: i
                assign height_key = 'payment_height_' | append: i
                assign w = section.settings[width_key]
                assign h = section.settings[height_key]
              -%}
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="Payment gateway"
                  class="system-img-{{ section.id }}"
                  style="width: {{ w }}px; height: {{ h }}px;"
                  loading="lazy"
                  height="auto"
                  width="auto"
                >
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <!-- Shipping System -->
        <div class="system-block-{{ section.id }} shipping-block-{{ section.id }}">
          <h4>{{ section.settings.shipping_title }}</h4>
          <div class="system-images-{{ section.id }}">
            {%- for i in (1..6) -%}
              {%- liquid
                assign img_key = 'shipping_img_' | append: i
                assign img = section.settings[img_key]
                assign width_key = 'shipping_width_' | append: i
                assign height_key = 'shipping_height_' | append: i
                assign w = section.settings[width_key]
                assign h = section.settings[height_key]
              -%}
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="Shipping carrier"
                  class="system-img-{{ section.id }}"
                  style="width: {{ w }}px; height: {{ h }}px;"
                  loading="lazy"
                  height="auto"
                  width="auto"
                >
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <!-- Social Links -->
        <div class="system-block-{{ section.id }} social-block-{{ section.id }}">
          <h4>{{ section.settings.socials_title }}</h4>
          <div class="social-links-{{ section.id }}">
            {%- if section.settings.facebook_link != blank -%}
              <a
                href="{{ section.settings.facebook_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} facebook"
                aria-label="Facebook"
              >
                <i class="fab fa-facebook-f"></i>
              </a>
            {%- endif -%}
            {%- if section.settings.instagram_link != blank -%}
              <a
                href="{{ section.settings.instagram_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} instagram"
                aria-label="Instagram"
              >
                <i class="fab fa-instagram"></i>
              </a>
            {%- endif -%}
            {%- if section.settings.youtube_link != blank -%}
              <a
                href="{{ section.settings.youtube_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} youtube"
                aria-label="YouTube"
              >
                <i class="fab fa-youtube"></i>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 3: Systems & Socials (TABLET & MOBILE VERSION) -->
  <div
    id="footer-systems-mobile-{{ section.id }}"
    class="footer-systems-{{ section.id }} footer-systems-mobile-{{ section.id }}"
  >
    <div class="container-fluid px-4 px-md-5">
      <div class="systems-mobile-row1-{{ section.id }}">
        <!-- Payment System -->
        <div class="system-block-{{ section.id }} payment-block-{{ section.id }}">
          <h4>{{ section.settings.payment_title }}</h4>
          <div class="system-images-{{ section.id }}">
            {%- for i in (1..6) -%}
              {%- liquid
                assign img_key = 'payment_img_' | append: i
                assign img = section.settings[img_key]
                assign width_key = 'payment_width_' | append: i
                assign height_key = 'payment_height_' | append: i
                assign w = section.settings[width_key]
                assign h = section.settings[height_key]
              -%}
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="Payment gateway"
                  class="system-img-{{ section.id }}"
                  style="width: {{ w }}px; height: {{ h }}px;"
                  loading="lazy"
                  height="auto"
                  width="auto"
                >
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>

        <!-- Shipping System -->
        <div class="system-block-{{ section.id }} shipping-block-{{ section.id }}">
          <h4>{{ section.settings.shipping_title }}</h4>
          <div class="system-images-{{ section.id }}">
            {%- for i in (1..6) -%}
              {%- liquid
                assign img_key = 'shipping_img_' | append: i
                assign img = section.settings[img_key]
                assign width_key = 'shipping_width_' | append: i
                assign height_key = 'shipping_height_' | append: i
                assign w = section.settings[width_key]
                assign h = section.settings[height_key]
              -%}
              {%- if img != blank -%}
                <img
                  src="{{ img | image_url: width: 120 }}"
                  alt="Shipping carrier"
                  class="system-img-{{ section.id }}"
                  style="width: {{ w }}px; height: {{ h }}px;"
                  loading="lazy"
                  height="auto"
                  width="auto"
                >
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </div>

      <div class="systems-mobile-row2-{{ section.id }}">
        <!-- Social Links -->
        <div class="system-block-{{ section.id }} social-block-{{ section.id }}">
          <h4>{{ section.settings.socials_title }}</h4>
          <div class="social-links-{{ section.id }}">
            {%- if section.settings.facebook_link != blank -%}
              <a
                href="{{ section.settings.facebook_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} facebook"
                aria-label="Facebook"
              >
                <i class="fab fa-facebook-f"></i>
              </a>
            {%- endif -%}
            {%- if section.settings.instagram_link != blank -%}
              <a
                href="{{ section.settings.instagram_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} instagram"
                aria-label="Instagram"
              >
                <i class="fab fa-instagram"></i>
              </a>
            {%- endif -%}
            {%- if section.settings.youtube_link != blank -%}
              <a
                href="{{ section.settings.youtube_link }}"
                target="_blank"
                class="social-icon-btn-{{ section.id }} youtube"
                aria-label="YouTube"
              >
                <i class="fab fa-youtube"></i>
              </a>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SECTION 4: Copyright Bottom -->
  <div class="footer-bottom-{{ section.id }}">
    <div class="container-fluid px-4 px-md-5">
      {%- if section.settings.copyright_text != blank -%}
        <p class="copyright-text-{{ section.id }}">{{ section.settings.copyright_text }}</p>
      {%- endif -%}
    </div>
  </div>
</div>

