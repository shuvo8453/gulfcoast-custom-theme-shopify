<section class="main-cart-section py-5">
  <div class="container">
    {% render 'breadcrumb' %}

    <h1 class="fw-bold text-dark mb-4"><i class="fa-solid fa-bag-shopping text-primary me-2"></i>{{ 'cart.general.title' | t }}</h1>

    {% if cart.item_count > 0 %}
      <form action="/cart" method="post" novalidate class="cart-form row g-5 mt-2">
        <!-- Cart Items List Table (9 Columns) -->
        <div class="col-12 col-lg-8">
          <div class="table-responsive border rounded bg-white shadow-sm">
            <table class="table shop_table mb-0 align-middle">
              <thead>
                <tr>
                  <th scope="col" class="ps-4">Product</th>
                  <th scope="col" class="text-center">Price</th>
                  <th scope="col" class="text-center">Quantity</th>
                  <th scope="col" class="text-end pe-4">Total</th>
                </tr>
              </thead>
              <tbody>
                {% for item in cart.items %}
                  <tr data-item-key="{{ item.key }}" class="border-bottom">
                    <td class="ps-4 py-3">
                      <div class="d-flex gap-3 align-items-center">
                        <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="text-danger" title="Remove item"><i class="fa-solid fa-trash-can"></i></a>
                        <img src="{{ item.image | image_url: width: 150 }}" class="rounded border" style="width: 70px; height: 70px; object-fit: cover;" alt="{{ item.product.title | escape }}">
                        <div>
                          <h6 class="mb-0 text-dark fw-bold"><a href="{{ item.url }}" class="text-dark">{{ item.product.title }}</a></h6>
                          {% unless item.product.has_only_default_variant %}
                            <span class="text-muted small d-block mt-1">{{ item.variant.title }}</span>
                          {% endunless %}
                        </div>
                      </div>
                    </td>
                    <td class="text-center text-muted fw-medium">{{ item.price | money }}</td>
                    <td class="text-center">
                      <div class="d-flex justify-content-center">
                        <div class="quantity-controls scale-90">
                          <button type="button" class="qty-btn qty-minus" aria-label="Decrease"><i class="fa-solid fa-minus"></i></button>
                          <div class="qty-divider"></div>
                          <input type="number" name="updates[]" class="qty-input" value="{{ item.quantity }}" data-key="{{ item.key }}" min="0">
                          <div class="qty-divider"></div>
                          <button type="button" class="qty-btn qty-plus" aria-label="Increase"><i class="fa-solid fa-plus"></i></button>
                        </div>
                      </div>
                    </td>
                    <td class="text-end pe-4 fw-bold text-primary">{{ item.final_line_price | money }}</td>
                  </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
          
          <div class="d-flex justify-content-between mt-3 px-1">
            <button type="submit" name="update" class="btn btn-outline-secondary rounded-pill btn-sm px-4">Update Cart</button>
            <a href="/collections/all" class="btn btn-outline-primary rounded-pill btn-sm px-4">{{ 'cart.general.continue_shopping' | t }}</a>
          </div>
        </div>

        <!-- Summary & Subtotal Sidebar (4 Columns) -->
        <div class="col-12 col-lg-4">
          <div class="cart-summary p-4 border rounded bg-light shadow-sm">
            <h4 class="fw-bold text-dark mb-4 border-bottom pb-2">Order Summary</h4>
            <div class="d-flex justify-content-between fw-bold fs-5 mb-4 text-dark">
              <span>{{ 'cart.general.subtotal' | t }}</span>
              <span>{{ cart.total_price | money }}</span>
            </div>
            
            <p class="text-muted small mb-4">Taxes, shipping, and promotional discount codes are computed during checkout.</p>
            
            <button type="submit" name="checkout" class="btn btn-primary btn-lg w-100 rounded-pill text-uppercase py-3">
              <i class="fa-solid fa-credit-card me-2"></i>{{ 'cart.general.checkout' | t }}
            </button>
          </div>
        </div>
      </form>
    {% else %}
      <div class="text-center py-5 border rounded bg-light mt-4">
        <i class="fa-solid fa-bag-shopping fa-4x text-muted mb-3"></i>
        <p class="text-muted mb-4">{{ 'cart.general.empty' | t }}</p>
        <a href="/collections/all" class="btn btn-primary rounded-pill px-5 py-3 text-uppercase fw-semibold">{{ 'cart.general.continue_shopping' | t }}</a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .scale-90 {
    transform: scale(0.9);
  }
</style>
