<section class="product-page-section py-5" data-section-id="{{ section.id }}" data-section-type="product">
  <div class="container">
    {% render 'breadcrumb' %}

    <div class="row g-5 mt-2">
      <!-- Left: Product Media Gallery -->
      <div class="col-12 col-md-6">
        <div class="product-gallery">
          <div class="main-image-wrapper border rounded overflow-hidden mb-3">
            {% if product.selected_or_first_available_variant.featured_image != blank %}
              <img src="{{ product.selected_or_first_available_variant.featured_image | image_url: width: 800 }}" 
                   id="ProductMainImage" 
                   class="img-fluid w-100" 
                   alt="{{ product.title | escape }}"
                   loading="eager">
            {% else %}
              <img src="{{ product.featured_image | image_url: width: 800 }}" 
                   id="ProductMainImage" 
                   class="img-fluid w-100" 
                   alt="{{ product.title | escape }}"
                   loading="eager">
            {% endif %}
          </div>
          
          {% if product.media.size > 1 %}
            <div class="row g-2 thumb-images-grid">
              {% for media in product.media %}
                <div class="col-3">
                  <div class="thumb-wrapper border rounded overflow-hidden cursor-pointer {% if forloop.first %}active border-primary{% endif %}" onclick="changeProductMainImage('{{ media | image_url: width: 800 }}', this)">
                    <img src="{{ media | image_url: width: 150 }}" class="img-fluid w-100" alt="{{ product.title | escape }}" loading="lazy">
                  </div>
                </div>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>

      <!-- Right: Product Information & Purchase -->
      <div class="col-12 col-md-6">
        <div class="product-details-panel">
          <!-- Vendor / Title -->
          <span class="text-uppercase text-muted small fw-bold tracking-wider">{{ product.vendor }}</span>
          <h1 class="product-title fw-bold my-2 text-dark">{{ product.title }}</h1>

          <!-- Review Stars Overlay -->
          <div class="product-reviews-badge my-3">
            <span class="text-warning"><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i></span>
            <span class="text-muted small ms-2">(Customer Reviews)</span>
          </div>

          <!-- Price -->
          <div class="product-price-container my-3 d-flex align-items-center gap-3">
            <span class="fs-3 fw-bold text-primary">{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
              <span class="fs-5 text-muted text-decoration-line-through">{{ product.compare_at_price | money }}</span>
              <span class="badge bg-danger">Save {{ product.compare_at_price | minus: product.price | money }}</span>
            {% endif %}
          </div>

          <!-- Est Arrival Widget -->
          <div class="est-arrival-badge alert alert-info py-2 px-3 my-4 d-flex align-items-center gap-2 border-0 rounded" style="background-color: #eff6ff; color: #1e3a8a;">
            <i class="fa-solid fa-truck-fast"></i>
            <span class="small fw-semibold">
              <!-- Liquid Date Math: Default to adding 3 days -->
              {% assign delivery_seconds = 259200 %}
              {{ 'products.product.arrives_by' | t: date: html | replace: "html", "" }}
              <strong id="dynamic-arrival-date"></strong>
            </span>
          </div>

          <!-- Add to Cart Form -->
          {% form 'product', product, id: 'AddToCartForm', class: 'purchase-form my-4' %}
            <!-- Hidden Input for selected variant -->
            <input type="hidden" name="id" id="SelectedVariantId" value="{{ product.selected_or_first_available_variant.id }}">

            <!-- Variant Selector Dropdowns (Standard Shopify option loop) -->
            {% unless product.has_only_default_variant %}
              <div class="product-option-selectors d-flex flex-column gap-3 mb-4">
                {% for option in product.options_with_values %}
                  <div class="option-row">
                    <label class="form-label fw-semibold text-dark small" for="Option-{{ forloop.index0 }}">
                      {{ option.name }}
                    </label>
                    <select id="Option-{{ forloop.index0 }}" class="form-select variant-select-input" onchange="onVariantOptionChange()">
                      {% for value in option.values %}
                        <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>
                          {{ value }}
                        </option>
                      {% endfor %}
                    </select>
                  </div>
                {% endfor %}
              </div>
            {% endunless %}

            <!-- Quantity & CTA Actions -->
            <div class="purchase-actions d-flex flex-wrap gap-3 align-items-center">
              <div>
                <label class="form-label text-muted small d-block mb-1">{{ 'products.product.quantity' | t }}</label>
                {% render 'quantity-selector' %}
              </div>

              <div class="flex-grow-1 align-self-end">
                <button type="submit" name="add" id="AddToCartButton" class="btn btn-primary w-100 btn-lg rounded-pill text-uppercase py-3 d-flex align-items-center justify-content-center gap-2" {% unless product.available %}disabled{% endunless %}>
                  {% if product.available %}
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span>{{ 'products.product.add_to_cart' | t }}</span>
                  {% else %}
                    <span>{{ 'products.product.sold_out' | t }}</span>
                  {% endif %}
                </button>
              </div>
            </div>
          {% endform %}

          <!-- Support Assistance Box -->
          {% render 'assistance-box' %}
        </div>
      </div>
    </div>

    <!-- Product Details Tabs -->
    <div class="row mt-5 pt-4">
      <div class="col-12">
        <ul class="nav nav-tabs border-bottom mb-4" id="productDetailTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link nav-link-custom active" id="desc-tab" data-bs-toggle="tab" data-bs-target="#desc-pane" type="button" role="tab" aria-controls="desc-pane" aria-selected="true">
              {{ 'products.product.description' | t }}
            </button>
          </li>
          {% if product.metafields.custom.specifications.value != blank %}
            <li class="nav-item" role="presentation">
              <button class="nav-link nav-link-custom" id="spec-tab" data-bs-toggle="tab" data-bs-target="#spec-pane" type="button" role="tab" aria-controls="spec-pane" aria-selected="false">
                {{ 'products.product.specifications' | t }}
              </button>
            </li>
          {% endif %}
          {% if product.metafields.custom.owners_manual != blank %}
            <li class="nav-item" role="presentation">
              <button class="nav-link nav-link-custom" id="manual-tab" data-bs-toggle="tab" data-bs-target="#manual-pane" type="button" role="tab" aria-controls="manual-pane" aria-selected="false">
                {{ 'products.product.manuals' | t }}
              </button>
            </li>
          {% endif %}
        </ul>
        <div class="tab-content px-2" id="productDetailTabsContent">
          <!-- Tab 1: Description -->
          <div class="tab-pane fade show active leading-relaxed text-muted" id="desc-pane" role="tabpanel" aria-labelledby="desc-tab" tabindex="0">
            {{ product.description }}
          </div>
          
          <!-- Tab 2: Specifications -->
          {% if product.metafields.custom.specifications.value != blank %}
            <div class="tab-pane fade" id="spec-pane" role="tabpanel" aria-labelledby="spec-tab" tabindex="0">
              <table class="table table-striped table-bordered mt-2">
                <tbody>
                  {% for spec in product.metafields.custom.specifications.value %}
                    {% assign spec_split = spec | split: ":" %}
                    <tr>
                      <th class="w-25 text-dark fw-semibold" scope="row">{{ spec_split[0] | strip }}</th>
                      <td class="text-muted">{{ spec_split[1] | strip }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% endif %}

          <!-- Tab 3: Downloads & Manuals -->
          {% if product.metafields.custom.owners_manual != blank %}
            <div class="tab-pane fade" id="manual-pane" role="tabpanel" aria-labelledby="manual-tab" tabindex="0">
              <div class="d-flex flex-column gap-3 p-2">
                <div class="d-flex align-items-center gap-3 p-3 bg-light rounded border">
                  <i class="fa-regular fa-file-pdf fa-2x text-danger"></i>
                  <div class="flex-grow-1">
                    <h6 class="mb-1 text-dark fw-bold">Owner's Installation & Operation Manual</h6>
                    <span class="text-muted small">PDF Document</span>
                  </div>
                  <a href="{{ product.metafields.custom.owners_manual | file_url }}" class="btn btn-outline-primary btn-sm rounded-pill px-3" target="_blank">
                    <i class="fa-solid fa-download me-1"></i>Download
                  </a>
                </div>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Desktop Sticky Add to Cart Footer Bar -->
<div id="sticky-cart-bar" class="sticky-cart-bar d-none d-md-block bg-white border-top shadow py-3 position-fixed bottom-0 start-0 w-100" style="z-index: 1000; transform: translateY(100%); transition: transform 0.4s ease;">
  <div class="container d-flex justify-content-between align-items-center">
    <div class="d-flex align-items-center gap-3">
      <img src="{{ product.featured_image | image_url: width: 100 }}" class="rounded border" style="width: 50px; height: 50px; object-fit: cover;" alt="{{ product.title | escape }}">
      <div>
        <h6 class="mb-0 text-dark fw-bold">{{ product.title }}</h6>
        <span class="fw-bold text-primary">{{ product.price | money }}</span>
      </div>
    </div>
    <div class="d-flex align-items-center gap-3">
      <button type="button" class="btn btn-primary rounded-pill text-uppercase px-4 py-2" onclick="document.getElementById('AddToCartButton').click()">
        <i class="fa-solid fa-cart-shopping me-2"></i>Add to Cart
      </button>
    </div>
  </div>
</div>

<!-- Inline JavaScript Helper Functions for Product Page -->
<script>
  function changeProductMainImage(url, thumbElement) {
    const mainImg = document.getElementById('ProductMainImage');
    if (mainImg) {
      mainImg.src = url;
    }
    // Update active border state
    document.querySelectorAll('.thumb-wrapper').forEach(el => el.classList.remove('active', 'border-primary'));
    thumbElement.classList.add('active', 'border-primary');
  }

  // Variant Change Calculations
  const productVariants = {{ product.variants | json }};
  
  function onVariantOptionChange() {
    // Collect selected option values
    const selectedOptions = [];
    const selectElements = document.querySelectorAll('.variant-select-input');
    selectElements.forEach(select => {
      selectedOptions.push(select.value);
    });

    // Find match
    const matchedVariant = productVariants.find(variant => {
      let isMatch = true;
      variant.options.forEach((opt, index) => {
        if (opt !== selectedOptions[index]) {
          isMatch = false;
        }
      });
      return isMatch;
    });

    if (matchedVariant) {
      // Update hidden input
      document.getElementById('SelectedVariantId').value = matchedVariant.id;

      // Update CTA state
      const addBtn = document.getElementById('AddToCartButton');
      if (matchedVariant.available) {
        addBtn.disabled = false;
        addBtn.querySelector('span').textContent = window.theme.strings.addToCart;
      } else {
        addBtn.disabled = true;
        addBtn.querySelector('span').textContent = window.theme.strings.soldOut;
      }

      // Update price display
      const priceContainer = document.querySelector('.product-price-container');
      if (priceContainer) {
        // Formatter function (simplified formatMoney)
        const formatString = window.theme ? window.theme.moneyFormat : "$ {{amount}}";
        const formattedPrice = formatString.replace(/\{\{\s*(\w+)\s*\}\}/, (matchedVariant.price / 100.0).toFixed(2));
        priceContainer.querySelector('.text-primary').textContent = formattedPrice;
      }

      // Update main image if variant has featured image
      if (matchedVariant.featured_image) {
        const mainImg = document.getElementById('ProductMainImage');
        if (mainImg) {
          mainImg.src = matchedVariant.featured_image.src;
        }
      }
    }
  }

  // Compute dynamic arrival date on product load
  document.addEventListener('DOMContentLoaded', () => {
    const arrivalSpan = document.getElementById('dynamic-arrival-date');
    if (arrivalSpan) {
      const today = new Date();
      // Add 3 days
      today.setDate(today.getDate() + 3);
      const options = { month: 'short', day: 'numeric', weekday: 'short' };
      arrivalSpan.textContent = today.toLocaleDateString('en-US', options);
    }

    // Bind sticky cart visibility scroll monitor
    const triggerBtn = document.getElementById('AddToCartButton');
    const stickyBar = document.getElementById('sticky-cart-bar');
    if (triggerBtn && stickyBar) {
      window.addEventListener('scroll', () => {
        const bounds = triggerBtn.getBoundingClientRect();
        if (bounds.bottom < 0) {
          stickyBar.classList.remove('d-none');
          stickyBar.style.transform = 'translateY(0)';
        } else {
          stickyBar.style.transform = 'translateY(100%)';
        }
      });
    }
  });
</script>

{% schema %}
{
  "name": "Product Details",
  "settings": [
    {
      "type": "text",
      "id": "help_phone",
      "label": "Assistance Phone Number",
      "default": "(850) 555-0199"
    },
    {
      "type": "text",
      "id": "help_email",
      "label": "Assistance Email Address",
      "default": "support@gulfcoastoutfitters.com"
    },
    {
      "type": "text",
      "id": "help_hours",
      "label": "Operating Hours",
      "default": "9:00 AM - 6:00 PM EST"
    }
  ]
}
{% endschema %}
