/* ==========================================================================
   GULF COAST OUTFITTERS - GLOBAL CUSTOM STYLESHEET (SHOPIFY 2.0)
   ========================================================================== */

:root {
  --color-primary: {{ settings.color_primary | default: '#062e67' }};
  --color-primary-hover: {{ settings.color_primary_hover | default: '#0b3d77' }};
  --color-background: {{ settings.color_background | default: '#ffffff' }};
  --color-text: {{ settings.color_text | default: '#4b5563' }};
  --color-heading: {{ settings.color_heading | default: '#1f2937' }};
  --color-accent: {{ settings.color_accent | default: '#3b82f6' }};
  --color-success: {{ settings.color_success | default: '#10b981' }};
  --color-error: {{ settings.color_error | default: '#ef4444' }};
  
  --font-family-body: 'Inter', sans-serif;
  --font-family-heading: 'Outfit', sans-serif;
  
  --border-radius-desktop: 60px;
  --border-radius-mobile: 40px;
  --border-radius-small: 8px;
}

/* Global Reset & Body */
body {
  font-family: var(--font-family-body);
  color: var(--color-text);
  background-color: var(--color-background);
  font-size: 1rem;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

h1, h2, h3, h4, h5, h6 {
  font-family: var(--font-family-heading);
  color: var(--color-heading);
  font-weight: 700;
  line-height: 1.3;
}

a {
  color: var(--color-primary);
  text-decoration: none;
  transition: color 0.2s ease-in-out;
}
a:hover {
  color: var(--color-primary-hover);
  text-decoration: none;
}

/* Utilities */
.gcf-section-padding {
  padding: 80px 0;
}
.gcf-section-subtitle {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 20px;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.gcf-section-title {
  font-size: 40px;
  font-weight: 700;
  color: var(--color-heading);
  margin-bottom: 24px;
  line-height: 1.25;
}
.gcf-section-content {
  font-size: 16px;
  line-height: 1.8;
  color: var(--color-text);
  margin-bottom: 32px;
}
.gcf-image-wrapper-rounded {
  position: relative;
  border-radius: var(--border-radius-desktop);
  overflow: hidden;
  line-height: 0;
  box-shadow: 0 10px 30px rgba(0,0,0,0.05);
}
.gcf-image-wrapper-rounded img {
  width: 100%;
  height: auto;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.gcf-image-wrapper-rounded:hover img {
  transform: scale(1.03);
}

@media (max-width: 991px) {
  .gcf-section-padding {
    padding: 60px 0;
  }
  .gcf-section-title {
    font-size: 32px;
  }
  .gcf-image-wrapper-rounded {
    border-radius: var(--border-radius-mobile);
    margin-bottom: 40px;
  }
}
@media (max-width: 575px) {
  .gcf-section-title {
    font-size: 28px;
  }
}

/* Custom Buttons */
.btn-primary {
  background-color: var(--color-primary);
  border-color: var(--color-primary);
  border-radius: 60px;
  padding: 12px 30px;
  font-weight: 600;
  font-family: var(--font-family-heading);
  transition: all 0.3s ease;
}
.btn-primary:hover, .btn-primary:focus {
  background-color: var(--color-primary-hover);
  border-color: var(--color-primary-hover);
  box-shadow: 0 4px 12px rgba(6, 46, 103, 0.2);
}

/* Custom Quantity Controls */
.quantity-controls {
  display: flex;
  align-items: center;
  border: 1px solid #e5e7eb;
  border-radius: 60px;
  height: 48px;
  padding: 0 4px;
  background: #fff;
  width: 125px;
  justify-content: space-between;
}
.qty-btn {
  width: 36px !important;
  height: 36px !important;
  border: none !important;
  background: transparent !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  cursor: pointer !important;
  color: var(--color-heading) !important;
  transition: all 0.3s ease !important;
  border-radius: 50% !important;
  padding: 0 !important;
}
.qty-btn:hover {
  background-color: #f3f4f6 !important;
}
.qty-divider {
  width: 1px;
  height: 24px;
  background-color: #e5e7eb;
}
.quantity-controls .qty-input {
  width: 40px !important;
  height: 100% !important;
  border: none !important;
  text-align: center !important;
  font-size: 16px !important;
  font-weight: 600 !important;
  color: var(--color-heading) !important;
  background: transparent !important;
  padding: 0 !important;
}
.qty-input:focus {
  outline: none !important;
}
.qty-input::-webkit-outer-spin-button,
.qty-input::-webkit-inner-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.qty-input[type="number"] {
  appearance: textfield;
  -moz-appearance: textfield;
}

/* Header Styles */
.top-header {
  background-color: #042048;
  color: #e2e8f0;
  font-size: 13px;
  padding: 8px 0;
}
.main-header {
  background-color: var(--color-primary);
  padding: 15px 0;
  border-bottom: 1px solid rgba(255,255,255,0.1);
}
.navigation-bar {
  background-color: var(--color-primary-hover);
  padding: 10px 0;
}
.main-header .search-container form {
  border-radius: 60px;
  overflow: hidden;
  background-color: #fff;
  display: flex;
}
.main-header .search-container input {
  border: none;
  padding: 10px 20px;
  outline: none;
  font-size: 14px;
}
.main-header .search-container button {
  border: none;
  background: #f1f5f9;
  padding: 0 20px;
  color: var(--color-primary);
}
.header-actions a {
  color: #fff;
  position: relative;
  font-size: 20px;
  margin-left: 20px;
}
.header-actions .badge {
  position: absolute;
  top: -8px;
  right: -10px;
  background: var(--color-accent);
  color: #fff;
  font-size: 10px;
  padding: 3px 6px;
  border-radius: 50%;
}
.nav-link {
  color: rgba(255,255,255,0.95);
  font-family: var(--font-family-heading);
  font-weight: 500;
  padding: 8px 15px !important;
}
.nav-link:hover {
  color: #fff;
}

/* Footer Styles */
.site-footer {
  background-color: #0b1a30;
  color: #cbd5e1;
  padding: 70px 0 30px;
  font-size: 14px;
}
.site-footer h5 {
  color: #ffffff;
  font-weight: 600;
  margin-bottom: 24px;
  font-size: 16px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.site-footer ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.site-footer ul li {
  margin-bottom: 12px;
}
.site-footer ul li a {
  color: #cbd5e1;
}
.site-footer ul li a:hover {
  color: #ffffff;
  padding-left: 5px;
}
.footer-newsletter input {
  border-radius: 60px 0 0 60px;
  border: none;
  padding: 10px 20px;
  background: rgba(255,255,255,0.08);
  color: #fff;
}
.footer-newsletter input::placeholder {
  color: #94a3b8;
}
.footer-newsletter button {
  border-radius: 0 60px 60px 0;
  background: var(--color-primary);
  color: #fff;
  border: none;
  padding: 0 20px;
}
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  margin-top: 50px;
  padding-top: 30px;
}

/* Product Card */
.product-card {
  background: #ffffff;
  border: 1px solid #f1f5f9;
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
  position: relative;
}
.product-card:hover {
  box-shadow: 0 12px 30px rgba(0,0,0,0.06);
  transform: translateY(-4px);
}
.product-card-image {
  position: relative;
  overflow: hidden;
  /* padding-top: 100%; */
  height: 300px;
  width: auto;
}
.product-card-image img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
.product-card:hover .product-card-image img {
  transform: scale(1.05);
}
.product-card-actions {
  position: absolute;
  top: 12px;
  right: 12px;
  display: flex;
  flex-direction: column;
  gap: 8px;
  z-index: 2;
  opacity: 0;
  transform: translateX(10px);
  transition: all 0.3s ease;
}
.product-card:hover .product-card-actions {
  opacity: 1;
  transform: translateX(0);
}
.card-action-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--color-heading);
  transition: all 0.2s ease;
}
.card-action-btn:hover {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}
.product-card-info {
  padding: 16px;
  background-color: #ecf1f4;
}
.product-card-title {
  font-size: 15px;
  font-weight: 600;
  margin-bottom: 8px;
  height: 44px;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.product-card-price {
  font-size: 16px;
  font-weight: 700;
  color: var(--color-primary);
}

/* Feature Popup Toasts */
.cart-recovery-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 320px;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.1);
  padding: 16px;
  z-index: 1000;
  transition: all 0.4s ease;
}
.toast-header {
  border-bottom: 1px solid #f1f5f9;
  padding-bottom: 8px;
}

/* Mobile Floating Navigation */
.mobile-floating-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 60px;
  background: #ffffff;
  box-shadow: 0 -4px 15px rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  justify-content: space-around;
  z-index: 998;
  border-top: 1px solid #e2e8f0;
}
.mobile-nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: var(--color-text);
  font-size: 11px;
}
.mobile-nav-item i {
  font-size: 18px;
  margin-bottom: 2px;
}
.mobile-nav-item.active {
  color: var(--color-primary);
}

/* Custom Tabs & Accordions (Product page, FAQ) */
.nav-tabs .nav-link-custom {
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--color-text);
  font-weight: 600;
  padding: 12px 20px;
}
.nav-tabs .nav-link-custom.active {
  border-bottom-color: var(--color-primary);
  color: var(--color-primary);
}
.faq-trigger {
  font-family: var(--font-family-heading);
}
.faq-trigger[aria-expanded="true"] .faq-icon i {
  transform: rotate(45deg);
}
.faq-icon i {
  transition: transform 0.2s ease;
}

/* Custom Bundles section styles */
.gcf-bundle-section {
  background-color: #f8fafc;
}
.bundle-product-card {
  padding: 12px;
  background: #fff;
  border: 1px solid #e2e8f0;
  border-radius: 8px;
}

/* Breadcrumbs Banner */
.breadcrumb-banner {
  background-size: cover;
  background-position: center;
  position: relative;
  padding: 60px 0;
  color: #fff;
}
.breadcrumb-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(4, 32, 72, 0.7);
  z-index: 1;
}
.breadcrumb-banner .container {
  position: relative;
  z-index: 2;
}

@media(max-width: 767px) {
  body {
    padding-bottom: 60px; /* Offset for floating mobile navigation bar */
  }
}

/* ==========================================================================
   COLLECTION PAGE REDESIGN & SIDEBAR FILTERS
   ========================================================================== */

/* Floating Toggle Button for Filters on Mobile/Tablet */
.floating-filter-btn {
  width: 50px;
  height: 50px;
  border-radius: 50% !important;
  background-color: var(--color-primary) !important;
  border-color: var(--color-primary) !important;
  color: #ffffff !important;
  position: fixed;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2000; /* High z-index keeps it above page elements */
  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  transition: all 0.3s ease;
}

.floating-filter-btn:hover {
  background-color: var(--color-primary-hover) !important;
  transform: translateY(-50%) scale(1.05);
}

@media (max-width: 575.98px) {
  .floating-filter-btn {
    right: 12px; /* Slightly closer on very small viewports */
    width: 46px;
    height: 46px;
    font-size: 18px;
  }
}

/* Off-canvas sidebar configuration for mobile/tablet */
@media (max-width: 991.98px) {
  .collection-sidebar-column {
    position: fixed !important;
    top: 0;
    left: -320px;
    width: 300px;
    height: 100vh;
    background-color: #ffffff;
    z-index: 1050;
    transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 0 !important;
    overflow-y: auto;
  }
  
  .collection-sidebar-column.show-drawer {
    left: 0;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.15);
  }

  .collection-filters-sidebar {
    height: 100%;
    padding: 25px !important;
  }
}

.collection-filters-sidebar {
  padding: 0;
  background: transparent;
}

.collection-filters-sidebar .filter-group {
  margin-bottom: 45px !important; /* Large vertical gap between options */
}

/* Custom Overlay for Mobile Filters Drawer */
.collection-drawer-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.4);
  z-index: 1045;
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.collection-drawer-overlay.show {
  display: block;
  opacity: 1;
}

/* Stock Status Pill Badge styling */
.stock-status-pill {
  display: inline-flex;
  align-items: center;
  padding: 6px 14px;
  border-radius: 30px;
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
}

.stock-status-pill.stock-in {
  background-color: rgba(16, 185, 129, 0.08);
  color: #10b981;
  border: 1px solid rgba(16, 185, 129, 0.2);
}

.stock-status-pill.stock-out {
  background-color: rgba(239, 68, 68, 0.08);
  color: #ef4444;
  border: 1px solid rgba(239, 68, 68, 0.2);
}

.stock-status-pill i {
  font-size: 14px;
  margin-right: 6px;
}

/* Product Card Actions Grid Layout */
.product-card-buttons .card-action-btn {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: #ffffff;
  border: 1px solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: var(--color-heading);
  transition: all 0.2s ease;
  flex-shrink: 0;
}

.product-card-buttons .card-action-btn:hover {
  background-color: var(--color-primary);
  color: #ffffff;
  border-color: var(--color-primary);
}

.product-card-buttons .card-action-btn.active {
  background-color: var(--color-primary);
  color: #ffffff;
  border-color: var(--color-primary);
}

.product-card-btn-add, .product-card-btn-notify {
  font-family: var(--font-family-heading);
  font-weight: 600;
  font-size: 14px;
  transition: all 0.3s ease;
  height: 42px;
}

.product-card-btn-add:hover {
  background-color: var(--color-primary-hover) !important;
  box-shadow: 0 4px 10px rgba(6, 46, 103, 0.2);
}

.product-card-btn-notify:hover {
  background-color: #dc2626 !important;
  box-shadow: 0 4px 10px rgba(239, 68, 68, 0.2);
}

/* Rounded Circle Pagination Styling overrides */
.pagination .page-item .page-link {
  width: 40px;
  height: 40px;
  border-radius: 50% !important;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 !important;
  color: var(--color-heading);
  border: 1px solid #e2e8f0;
  background-color: #ffffff;
  font-weight: 600;
  margin: 0 4px;
  transition: all 0.2s ease;
}

.pagination .page-item.active .page-link,
.pagination .page-item.active .page-link:hover {
  background-color: var(--color-primary) !important;
  border-color: var(--color-primary) !important;
  color: #ffffff !important;
}

.pagination .page-item .page-link:hover {
  background-color: #f1f5f9;
  color: var(--color-primary);
  border-color: #cbd5e1;
}

/* Sidebar Headings with Accent Underline */
.sidebar-heading {
  font-size: 13px !important;
  font-weight: 800 !important;
  color: var(--color-heading);
  letter-spacing: 0.5px;
  position: relative;
  padding-bottom: 8px;
  margin-bottom: 15px;
  text-transform: uppercase;
}

.sidebar-heading::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 40px;
  height: 2px;
  background-color: var(--color-primary);
}

/* Sidebar Custom Form Selects */
.filter-group select.form-select {
  border-radius: 60px;
  padding: 10px 20px;
  font-size: 13px;
  border: 1px solid #cbd5e1;
  color: #4b5563;
  background-color: #ffffff;
  transition: all 0.2s ease-in-out;
  cursor: pointer;
}

.filter-group select.form-select:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(6, 46, 103, 0.15);
}

/* Featured Products in Sidebar */
.sidebar-product-item {
  transition: transform 0.2s ease;
}

.sidebar-product-item:hover {
  transform: translateX(4px);
}

.sidebar-product-item img {
  object-fit: cover;
  border-radius: 6px;
  transition: opacity 0.2s ease;
}

.sidebar-product-item:hover img {
  opacity: 0.9;
}

/* Mobile Override for Product Grid Cards (Two columns) */
@media (max-width: 575.98px) {
  .product-card-info {
    padding: 10px !important;
  }
  .product-card-title {
    font-size: 12px !important;
    height: 32px !important;
    margin-bottom: 4px !important;
    line-height: 1.3 !important;
  }
  .stock-status-pill {
    padding: 3px 8px !important;
    font-size: 9px !important;
  }
  .stock-status-pill i {
    font-size: 10px !important;
    margin-right: 3px !important;
  }
  .product-card-price {
    font-size: 13px !important;
    margin-bottom: 8px !important;
    padding-top: 4px !important;
    gap: 4px !important;
  }
  .product-card-buttons {
    gap: 4px !important;
  }
  .product-card-buttons .card-action-btn {
    width: 32px !important;
    height: 32px !important;
    font-size: 11px !important;
  }
  .product-card-btn-add, 
  .product-card-btn-notify {
    height: 32px !important;
    padding: 0 !important;
    font-size: 12px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }
}

/* Quick View Button Hover Behavior & Modal Styles */
.product-card-image .quick-view-btn {
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease, background-color 0.2s ease;
  transform: translateX(-50%) scale(0.9);
}

.product-card-image:hover .quick-view-btn {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) scale(1);
}

.product-card-image .quick-view-btn:hover {
  background-color: #dbeafe !important;
  color: #1e40af !important;
}

/* Modal Specs Scrollbar Styling */
.quick-view-specs-scroll::-webkit-scrollbar {
  width: 5px;
}
.quick-view-specs-scroll::-webkit-scrollbar-track {
  background: #f1f5f9;
  border-radius: 4px;
}
.quick-view-specs-scroll::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 4px;
}
.quick-view-specs-scroll::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}

/* Modal spec rows styling */
.quick-view-specs-scroll table tr {
  border-bottom: 1px solid #f1f5f9 !important;
}
.quick-view-specs-scroll table tr:last-child {
  border-bottom: none !important;
}
.quick-view-specs-scroll table td {
  padding: 8px 4px;
}


