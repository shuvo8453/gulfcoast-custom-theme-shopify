{%- style -%}
  #contact-section-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  @media screen and (min-width: 768px) {
    #contact-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    }
  }

  /* Contact Us Layout */
  .contact-wrapper-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .contact-grid-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .contact-image-wrapper-{{ section.id }} {
    width: 100%;
  }

  .contact-image-{{ section.id }} {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: {{ section.settings.image_border_radius }}px;
    display: block;
  }

  .contact-content-{{ section.id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    text-align: left;
  }

  .contact-heading-{{ section.id }} {
    font-family: {{ section.settings.heading_font_family }};
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-weight: {{ section.settings.heading_font_weight }};
    color: {{ section.settings.heading_color }};
    margin: 0 0 15px 0;
    line-height: 1.2;
  }

  .contact-subtitle-{{ section.id }} {
    font-family: {{ section.settings.subtitle_font_family }};
    font-size: {{ section.settings.subtitle_font_size_mobile }}px;
    font-weight: {{ section.settings.subtitle_font_weight }};
    color: {{ section.settings.subtitle_color }};
    margin: 0 0 30px 0;
    line-height: 1.5;
  }

  /* Form Styles */
  .contact-form-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group-{{ section.id }} {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label-{{ section.id }} {
    font-family: var(--font-primary--family);
    font-size: 14px;
    font-weight: 500;
    color: {{ section.settings.label_color }};
  }

  .form-input-{{ section.id }},
  .form-textarea-{{ section.id }} {
    width: 100%;
    padding: 12px 20px;
    border: 1px solid {{ section.settings.input_border_color }};
    background-color: {{ section.settings.input_bg_color }};
    border-radius: {{ section.settings.input_border_radius }}px;
    font-size: 16px;
    color: {{ section.settings.input_text_color }};
    outline: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .form-input-{{ section.id }}:focus,
  .form-textarea-{{ section.id }}:focus {
    border-color: {{ section.settings.button_bg_color }};
    box-shadow: 0 0 0 3px {{ section.settings.button_bg_color | color_modify: 'alpha', 0.15 }};
  }

  .form-textarea-{{ section.id }} {
    min-height: 150px;
    resize: vertical;
  }

  .form-submit-{{ section.id }} {
    align-self: flex-start;
    padding: 12px 30px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border: none;
    border-radius: {{ section.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.2s ease, transform 0.1s ease;
  }

  .form-submit-{{ section.id }}:hover {
    background-color: {{ section.settings.button_hover_bg_color }};
  }

  .form-submit-{{ section.id }}:active {
    transform: scale(0.98);
  }

  .form-status-{{ section.id }} {
    margin-bottom: 20px;
    padding: 15px;
    border-radius: 8px;
    font-size: 15px;
  }

  .form-status--success-{{ section.id }} {
    background-color: #d1e7dd;
    color: #0f5132;
    border: 1px solid #badbcc;
  }

  .form-status--error-{{ section.id }} {
    background-color: #f8d7da;
    color: #842029;
    border: 1px solid #f5c2c7;
  }

  /* Responsive styling: Tablet and Desktop split-screen layout */
  @media screen and (min-width: 768px) {
    .contact-grid-{{ section.id }} {
      flex-direction: row;
      align-items: center;
      gap: 50px;
    }

    .contact-image-wrapper-{{ section.id }} {
      flex: 1;
    }

    .contact-content-{{ section.id }} {
      flex: 1;
    }

    .contact-heading-{{ section.id }} {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
    }

    .contact-subtitle-{{ section.id }} {
      font-size: {{ section.settings.subtitle_font_size_desktop }}px;
    }
  }
{%- endstyle -%}

<section id="contact-section-{{ section.id }}">
  <div class="contact-wrapper-{{ section.id }}">
    <div class="contact-grid-{{ section.id }}">
      
      <!-- Image Section -->
      <div class="contact-image-wrapper-{{ section.id }}">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.image.alt | default: section.settings.heading }}"
            class="contact-image-{{ section.id }}"
            loading="lazy"
            width="800"
            height="auto"
          >
        {%- else -%}
          <!-- Fallback/Demo image -->
          <img
            src="{{ 'contact-us-placeholder.png' | asset_url }}"
            alt="Contact Us Demo Image"
            class="contact-image-{{ section.id }}"
            loading="lazy"
            width="800"
            height="auto"
          >
        {%- endif -%}
      </div>

      <!-- Content & Form Section -->
      <div class="contact-content-{{ section.id }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="contact-heading-{{ section.id }}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="contact-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- assign form_class = 'contact-form-' | append: section.id -%}
        {%- form 'contact', id: 'ContactForm', class: form_class -%}
          {%- if form.posted_successfully? -%}
            {%- assign success_msg = section.settings.success_message -%}
            {%- if success_msg == blank -%}
              {%- assign success_msg = 'templates.contact.form.post_success' | t -%}
              {%- if success_msg contains 'translation missing' or success_msg == blank -%}
                {%- assign success_msg = 'Thanks for contacting us. We will get back to you as soon as possible.' -%}
              {%- endif -%}
            {%- endif -%}
            <div class="form-status-{{ section.id }} form-status--success-{{ section.id }}" tabindex="-1" autofocus>
              <i class="fa-solid fa-circle-check me-2"></i>{{ success_msg }}
            </div>
          {%- elsif form.errors -%}
            {%- assign error_heading = 'templates.contact.form.error_heading' | t -%}
            {%- if error_heading contains 'translation missing' or error_heading == blank -%}
              {%- assign error_heading = 'Please adjust the following:' -%}
            {%- endif -%}
            <div class="form-status-{{ section.id }} form-status--error-{{ section.id }}" role="alert" tabindex="-1" autofocus>
              <i class="fa-solid fa-circle-exclamation me-2"></i>{{ error_heading }}
              <ul class="errors-list-{{ section.id }} mt-2 mb-0">
                {%- for field in form.errors -%}
                  <li>
                    {%- if field == 'form' -%}
                      {{ form.errors.messages[field] }}
                    {%- else -%}
                      <a href="#ContactForm-{{ field }}" class="text-danger">
                        {{ form.errors.translated_fields[field] | capitalize }} {{ form.errors.messages[field] }}
                      </a>
                    {%- endif -%}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}

          <!-- Name Field -->
          <div class="form-group-{{ section.id }}">
            <label class="form-label-{{ section.id }}" for="ContactForm-name">Your name</label>
            <input
              type="text"
              name="contact[name]"
              id="ContactForm-name"
              class="form-input-{{ section.id }}"
              value="{% if form.name %}{{ form.name }}{% elsif customer %}{{ customer.name }}{% endif %}"
              placeholder="Your name"
              required
            >
          </div>

          <!-- Email Field -->
          <div class="form-group-{{ section.id }}">
            <label class="form-label-{{ section.id }}" for="ContactForm-email">Your email</label>
            <input
              type="email"
              name="contact[email]"
              id="ContactForm-email"
              class="form-input-{{ section.id }}"
              value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
              placeholder="Your email"
              spellcheck="false"
              autocapitalize="off"
              required
            >
          </div>

          <!-- Subject Field -->
          <div class="form-group-{{ section.id }}">
            <label class="form-label-{{ section.id }}" for="ContactForm-subject">Subject</label>
            <input
              type="text"
              name="contact[subject]"
              id="ContactForm-subject"
              class="form-input-{{ section.id }}"
              value="{% if form.subject %}{{ form.subject }}{% endif %}"
              placeholder="Subject"
              required
            >
          </div>

          <!-- Message Field -->
          <div class="form-group-{{ section.id }}">
            <label class="form-label-{{ section.id }}" for="ContactForm-message">Your message (optional)</label>
            <textarea
              rows="6"
              name="contact[body]"
              id="ContactForm-message"
              class="form-textarea-{{ section.id }}"
              placeholder="Your message"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button type="submit" class="form-submit-{{ section.id }}">
            Send Message
          </button>
        {%- endform -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
