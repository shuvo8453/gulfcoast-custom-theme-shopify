<section class="wishlist-grid-section py-5">
  <div class="container">
    {% render 'breadcrumb' %}

    <div class="row mt-4">
      <div class="col-12">
        <h1 class="fw-bold text-dark mb-4"><i class="fa-regular fa-heart text-danger me-2"></i>{{ page.title }}</h1>

        <div id="wishlist-grid-items" class="row m-0 row-cols-1 row-cols-sm-2 row-cols-md-4 g-4 mt-2">
          <!-- Loaded dynamically via client-side storage -->
          <div class="col-12 text-center py-5" id="wishlist-preloader">
            <i class="fa-solid fa-spinner fa-spin fa-3x text-primary mb-3"></i>
            <p class="text-muted">Loading your wishlist items...</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const list = JSON.parse(localStorage.getItem('gcf_wishlist') || '[]');
    const grid = document.getElementById('wishlist-grid-items');
    const preloader = document.getElementById('wishlist-preloader');

    if (!grid) return;

    if (list.length === 0) {
      if (preloader) preloader.remove();
      grid.innerHTML = `
        <div class="col-12 text-center py-5 border rounded bg-light">
          <i class="fa-regular fa-heart fa-3x text-muted mb-3"></i>
          <p class="text-muted mb-3">Your wishlist is currently empty.</p>
          <a href="/collections/all" class="btn btn-primary rounded-pill px-4">Browse Products</a>
        </div>
      `;
      return;
    }

    const promises = list.map(
      (handle) =>
        fetch(`/products/${handle}.js`)
          .then((res) => {
            if (!res.ok) throw new Error();
            return res.json();
          })
          .catch(() => null) // Ignore missing products
    );

    Promise.all(promises)
      .then((products) => {
        if (preloader) preloader.remove();

        const validProducts = products.filter((p) => p !== null);
        if (validProducts.length === 0) {
          grid.innerHTML = `
            <div class="col-12 text-center py-5 border rounded bg-light">
              <i class="fa-regular fa-heart fa-3x text-muted mb-3"></i>
              <p class="text-muted mb-3">Your wishlist is currently empty.</p>
              <a href="/collections/all" class="btn btn-primary rounded-pill px-4">Browse Products</a>
            </div>
          `;
          return;
        }

        grid.innerHTML = validProducts
          .map((product) => {
            const formattedPrice = formatMoney(product.price);
            const comparePriceHtml =
              product.compare_at_price > product.price
                ? `<span class="text-muted text-decoration-line-through small ms-2">${formatMoney(
                    product.compare_at_price
                  )}</span>`
                : '';

            return `
            <div class="col">
              <div class="product-card">
                <div class="product-card-image">
                  <a href="${product.url}">
                    <img src="${product.featured_image}" class="img-fluid" alt="${product.title}" loading="lazy">
                  </a>
                  <div class="product-card-actions" style="opacity:1; transform:none;">
                    <button class="card-action-btn wishlist-btn-toggle" data-handle="${product.handle}" title="Remove from Wishlist">
                      <i class="fa-solid fa-trash-can text-danger"></i>
                    </button>
                  </div>
                </div>
                <div class="product-card-info">
                  <span class="text-uppercase text-muted small fw-bold" style="font-size:10px;">${product.vendor}</span>
                  <h6 class="product-card-title mt-1 mb-2"><a href="${product.url}" class="text-dark fw-bold text-decoration-none">${product.title}</a></h6>
                  <div class="product-card-price">
                    <span class="fw-bold text-primary">${formattedPrice}</span>
                    ${comparePriceHtml}
                  </div>
                </div>
              </div>
            </div>
          `;
          })
          .join('');
      })
      .catch((err) => {
        console.error('Failed to load wishlist items:', err);
        if (preloader) preloader.remove();
        grid.innerHTML = '<p class="text-danger text-center">An error occurred while loading your wishlist.</p>';
      });

    function formatMoney(cents) {
      const formatString = window.theme ? window.theme.moneyFormat : '$ {{amount}}';
      const placeholderRegex = /\{\{\s*(\w+)\s*\}\}/;

      if (isNaN(cents) || cents == null) return '$0.00';
      let formatted = (cents / 100.0).toFixed(2);

      return formatString.replace(placeholderRegex, formatted);
    }
  });
</script>
