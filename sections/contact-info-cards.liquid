{%- style -%}
  /* Section Spacing - Mobile */
  #contact-cards-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    margin-top: {{ section.settings.margin_top_mobile }}px;
    margin-bottom: {{ section.settings.margin_bottom_mobile }}px;
    background: {{ section.settings.bg_color }};
    {%- if section.settings.bg_gradient != blank -%}
      background: {{ section.settings.bg_gradient }};
    {%- endif -%}
  }

  /* Inner Container */
  .contact-cards-container-{{ section.id }} {
    max-width: {{ section.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
    padding-left: {{ section.settings.padding_horizontal_mobile }}px;
    padding-right: {{ section.settings.padding_horizontal_mobile }}px;
    box-sizing: border-box;
    width: 100%;
  }

  /* Layout - Mobile */
  .contact-cards-flex-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ section.settings.gap_mobile }}px;
  }

  /* Individual Card Item - Mobile */
  .contact-card-item-{{ section.id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
    max-width: 320px;
    padding: {{ section.settings.card_padding_mobile }}px;
    margin: {{ section.settings.card_margin_mobile }}px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  /* Icon Wrapper & Styling - Mobile */
  .contact-card-icon-{{ section.id }} {
    font-size: {{ section.settings.icon_size_mobile }}px;
    color: {{ section.settings.icon_color }};
    margin-bottom: {{ section.settings.icon_margin_bottom_mobile }}px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
  }

  /* Card Title - Mobile */
  .contact-card-title-{{ section.id }} {
    font-family: {{ section.settings.title_font_family }};
    font-size: {{ section.settings.title_size_mobile }}px;
    font-weight: {{ section.settings.title_font_weight }};
    color: {{ section.settings.title_color }};
    margin-top: {{ section.settings.title_margin_top_mobile }}px;
    margin-bottom: {{ section.settings.title_margin_bottom_mobile }}px;
    line-height: 1.3;
  }

  /* Card Subtitle/Detail - Mobile */
  .contact-card-subtitle-{{ section.id }} {
    font-family: {{ section.settings.subtitle_font_family }};
    font-size: {{ section.settings.subtitle_size_mobile }}px;
    font-weight: normal;
    color: {{ section.settings.subtitle_color }};
    margin-top: 0;
    margin-bottom: 0;
    line-height: 1.5;
    word-break: break-word;
  }

  /* Tablet Devices (576px to 767px) */
  @media screen and (min-width: 576px) {
    #contact-cards-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_tablet }}px;
      padding-bottom: {{ section.settings.padding_bottom_tablet }}px;
      margin-top: {{ section.settings.margin_top_tablet }}px;
      margin-bottom: {{ section.settings.margin_bottom_tablet }}px;
    }

    .contact-cards-container-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal_tablet }}px;
      padding-right: {{ section.settings.padding_horizontal_tablet }}px;
    }

    /* Tablet layout: side-by-side spaced-between */
    .contact-cards-flex-{{ section.id }} {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }

    .contact-card-item-{{ section.id }} {
      width: calc(33.333% - 14px);
      max-width: none;
      padding: {{ section.settings.card_padding_tablet }}px;
      margin: {{ section.settings.card_margin_tablet }}px;
    }

    .contact-card-icon-{{ section.id }} {
      font-size: {{ section.settings.icon_size_tablet }}px;
      margin-bottom: {{ section.settings.icon_margin_bottom_tablet }}px;
    }

    .contact-card-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_tablet }}px;
      margin-top: {{ section.settings.title_margin_top_tablet }}px;
      margin-bottom: {{ section.settings.title_margin_bottom_tablet }}px;
    }

    .contact-card-subtitle-{{ section.id }} {
      font-size: {{ section.settings.subtitle_size_tablet }}px;
    }
  }

  /* Desktop Devices (768px and up) */
  @media screen and (min-width: 768px) {
    #contact-cards-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_desktop }}px;
      padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
      margin-top: {{ section.settings.margin_top_desktop }}px;
      margin-bottom: {{ section.settings.margin_bottom_desktop }}px;
    }

    .contact-cards-container-{{ section.id }} {
      padding-left: {{ section.settings.padding_horizontal_desktop }}px;
      padding-right: {{ section.settings.padding_horizontal_desktop }}px;
    }

    /* Desktop layout: side-by-side spaced-between */
    .contact-cards-flex-{{ section.id }} {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-start;
      gap: 30px;
    }

    .contact-card-item-{{ section.id }} {
      width: calc(33.333% - 20px);
      max-width: none;
      padding: {{ section.settings.card_padding_desktop }}px;
      margin: {{ section.settings.card_margin_desktop }}px;
    }

    /* Hover effect to make it premium */
    {%- if section.settings.enable_hover_effect -%}
      .contact-card-item-{{ section.id }}:hover {
        transform: translateY(-4px);
      }
      .contact-card-item-{{ section.id }}:hover .contact-card-icon-{{ section.id }} {
        color: {{ section.settings.icon_hover_color }};
      }
    {%- endif -%}

    .contact-card-icon-{{ section.id }} {
      font-size: {{ section.settings.icon_size_desktop }}px;
      margin-bottom: {{ section.settings.icon_margin_bottom_desktop }}px;
    }

    .contact-card-title-{{ section.id }} {
      font-size: {{ section.settings.title_size_desktop }}px;
      margin-top: {{ section.settings.title_margin_top_desktop }}px;
      margin-bottom: {{ section.settings.title_margin_bottom_desktop }}px;
    }

    .contact-card-subtitle-{{ section.id }} {
      font-size: {{ section.settings.subtitle_size_desktop }}px;
    }
  }
{%- endstyle -%}

<section id="contact-cards-{{ section.id }}" class="contact-info-cards-section">
  <div class="contact-cards-container-{{ section.id }}">
    <div class="contact-cards-flex-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'contact_item' -%}
          {%- capture card_content -%}
            {%- if block.settings.icon != 'none' -%}
              <span class="contact-card-icon-{{ section.id }}" aria-hidden="true">
                {%- if block.settings.icon == 'map' -%}
                  <i class="fas fa-map-marker-alt"></i>
                {%- elsif block.settings.icon == 'email' -%}
                  <i class="fas fa-envelope"></i>
                {%- elsif block.settings.icon == 'phone' -%}
                  <i class="fas fa-phone-alt"></i>
                {%- endif -%}
              </span>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="contact-card-title-{{ section.id }}">{{ block.settings.title | escape }}</h3>
            {%- endif -%}

            {%- if block.settings.subtitle != blank -%}
              <p class="contact-card-subtitle-{{ section.id }}">{{ block.settings.subtitle | newline_to_br }}</p>
            {%- endif -%}
          {%- endcapture -%}

          {%- if block.settings.link != blank -%}
            <a
              href="{{ block.settings.link }}"
              class="contact-card-item-{{ section.id }}"
              {{ block.shopify_attributes }}
            >
              {{ card_content }}
            </a>
          {%- else -%}
            <div class="contact-card-item-{{ section.id }}" {{ block.shopify_attributes }}>
              {{ card_content }}
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

